#!/bin/bash

VERSION="2.3.1"

usage() {
    cat << EOF
Usage: rename-gp [OPTIONS] <directory>

Rename images and videos from a Google Photos Takeout export using JSON
sidecar metadata files. Files without a matching JSON sidecar are skipped.
JSON sidecars are deleted after metadata is written to the media file.

Iterates over JSON sidecars (not media files) and locates the corresponding
media file using the sidecar's "title" field. Media is searched within all
directories sharing the same folder name as the JSON (e.g. "Photos from 2019"),
so cross-takeout splits are handled correctly without a global media index.

Options:
    --dry-run, -n       Show what would be renamed without actually renaming
    --format <fmt>      Timestamp format (default: %Y%m%d_%H%M%S000)
    --debug             Show JSON-to-media match details for each processed file
    --help, -h          Show this help message
    --version, -v       Show version information

Supported formats:
    Images: .jpg, .jpeg, .png, .gif, .bmp, .tiff, .webp, .dng, .heic
    Videos: .mp4, .mov, .avi, .mkv, .m4v, .3gp

Format specifiers (date -d syntax):
    %Y %m %d %H %M %S   standard date/time components

Note:
    The JSON "title" field is used as the media filename. A duplicate counter
    (N) at the end of the JSON stem is moved before the extension in the media
    filename: foo.jpg.supplemental-metadata(1).json -> media is foo(1).jpg

    GPS coordinates, description, title, and date/time from JSON are written
    to the media file via exiftool after renaming (requires jq).
    Existing files with the same name will be avoided with numeric suffixes.

Examples:
    rename-gp --dry-run ~/extracted
    rename-gp ~/extracted
EOF
}

show_version() {
    echo "rename-gp version $VERSION"
}

DRY_RUN=0
DEBUG=0
TIMESTAMP_FORMAT="%Y%m%d_%H%M%S000"
TARGET_DIR=""

while [[ $# -gt 0 ]]; do
    case $1 in
        --dry-run|-n)
            DRY_RUN=1
            shift
            ;;
        --debug)
            DEBUG=1
            shift
            ;;
        --format)
            TIMESTAMP_FORMAT="$2"
            shift 2
            ;;
        --help|-h)
            usage
            exit 0
            ;;
        --version|-v)
            show_version
            exit 0
            ;;
        -*)
            echo "Error: Unknown option: $1"
            usage
            exit 1
            ;;
        *)
            if [[ -z "$TARGET_DIR" ]]; then
                TARGET_DIR="$1"
            else
                echo "Error: Multiple directories specified"
                usage
                exit 1
            fi
            shift
            ;;
    esac
done

if [[ -z "$TARGET_DIR" ]]; then
    echo "Error: No directory specified"
    usage
    exit 1
fi

if [[ ! -d "$TARGET_DIR" ]]; then
    echo "Error: Directory not found: $TARGET_DIR"
    exit 1
fi

if ! command -v jq &> /dev/null; then
    echo "Error: jq is required but not installed"
    exit 1
fi

if ! command -v exiftool &> /dev/null; then
    echo "Error: exiftool is required but not installed"
    exit 1
fi

# DIR_CACHE: dir_basename -> newline-separated list of full paths
# Allows looking up all directories with a given name (e.g. "Photos from 2019")
# without scanning the tree repeatedly. Built once at startup.
declare -A DIR_CACHE

build_dir_cache() {
    echo "Building directory cache..."
    local count=0
    while IFS= read -r -d '' dir_path; do
        local dir_name
        dir_name=$(basename "$dir_path")
        if [[ -n "${DIR_CACHE[$dir_name]}" ]]; then
            DIR_CACHE["$dir_name"]+=$'\n'"$dir_path"
        else
            DIR_CACHE["$dir_name"]="$dir_path"
        fi
        ((count++))
    done < <(find "$TARGET_DIR" -mindepth 1 -type d -print0 2>/dev/null)
    echo "Cached $count directories (${#DIR_CACHE[@]} unique names)"
    echo ""
}

# Find the media file for a given JSON sidecar.
# Searches all directories with the same name as the JSON's parent directory.
# Uses bash string comparison instead of find -iname to avoid glob interpretation
# of special characters like [ ] * ? in filenames.
find_media_for_json() {
    local media_name="$1"   # e.g. IMG_8843(1).JPG
    local dir_name="$2"     # e.g. Photos from 2018
    local media_name_lower="${media_name,,}"

    local candidates="${DIR_CACHE[$dir_name]}"
    [[ -z "$candidates" ]] && return 1

    # First pass: exact case-insensitive match
    while IFS= read -r candidate_dir; do
        [[ -z "$candidate_dir" ]] && continue
        while IFS= read -r -d '' f; do
            local fname="${f##*/}"
            if [[ "${fname,,}" == "$media_name_lower" ]]; then
                echo "$f"
                return 0
            fi
        done < <(find "$candidate_dir" -maxdepth 1 -type f -print0 2>/dev/null)
    done <<< "$candidates"

    # Second pass: prefix match for filenames truncated by Google Photos (~51 char limit)
    if [[ ${#media_name} -ge 47 ]]; then
        local prefix="${media_name_lower:0:46}"
        local ext="${media_name_lower##*.}"
        while IFS= read -r candidate_dir; do
            [[ -z "$candidate_dir" ]] && continue
            while IFS= read -r -d '' f; do
                local fname="${f##*/}"
                local fname_lower="${fname,,}"
                if [[ "$fname_lower" == "${prefix}"* && "$fname_lower" == *".$ext" ]]; then
                    echo "$f"
                    return 0
                fi
            done < <(find "$candidate_dir" -maxdepth 1 -type f -print0 2>/dev/null)
        done <<< "$candidates"
    fi

    return 1
}

write_json_metadata() {
    local file="$1"
    local json_file="$2"

    local timestamp lat lon alt desc title
    timestamp=$(jq -r '.photoTakenTime.timestamp // empty' "$json_file" 2>/dev/null)
    lat=$(jq -r '.geoData.latitude // empty' "$json_file" 2>/dev/null)
    lon=$(jq -r '.geoData.longitude // empty' "$json_file" 2>/dev/null)
    alt=$(jq -r '.geoData.altitude // empty' "$json_file" 2>/dev/null)
    desc=$(jq -r '.description // empty' "$json_file" 2>/dev/null)
    title=$(jq -r '.title // empty' "$json_file" 2>/dev/null)

    # Device/upload source: mobileUpload combines deviceType + localFolderName (app that saved the file)
    # e.g. "Android Phone / Telegram Images", "iOS Phone", "Backup and Sync"
    local raw_device_type local_folder_name device_source=""
    raw_device_type=$(jq -r '.googlePhotosOrigin.mobileUpload.deviceType // empty' "$json_file" 2>/dev/null)
    if [[ -n "$raw_device_type" ]]; then
        case "$raw_device_type" in
            IOS_PHONE)     device_source="iOS Phone" ;;
            ANDROID_PHONE) device_source="Android Phone" ;;
            *)             device_source="${raw_device_type//_/ }" ;;
        esac
        local_folder_name=$(jq -r '.googlePhotosOrigin.mobileUpload.deviceFolder.localFolderName // empty' "$json_file" 2>/dev/null)
        if [[ -n "$local_folder_name" ]]; then
            device_source+=" / $local_folder_name"
        fi
    else
        local raw_uploader
        raw_uploader=$(jq -r '.googlePhotosOrigin.driveDesktopUploader.version // empty' "$json_file" 2>/dev/null)
        if [[ -n "$raw_uploader" ]]; then
            case "$raw_uploader" in
                BACKUP_AND_SYNC) device_source="Backup and Sync" ;;
                *)               device_source="${raw_uploader//_/ }" ;;
            esac
        fi
    fi

    # People tagged in Google Photos: XMP:PersonInImage supports multiple values
    local -a people=()
    while IFS= read -r name; do
        [[ -n "$name" ]] && people+=("$name")
    done < <(jq -r '.people[]?.name // empty' "$json_file" 2>/dev/null)

    local exif_args=()

    if [[ -n "$timestamp" && "$timestamp" != "null" ]]; then
        local datetime
        datetime=$(date -d "@$timestamp" "+%Y:%m:%d %H:%M:%S" 2>/dev/null)
        if [[ -n "$datetime" ]]; then
            exif_args+=("-DateTimeOriginal=$datetime")
            exif_args+=("-CreateDate=$datetime")
            exif_args+=("-ModifyDate=$datetime")
        fi
    fi

    if [[ -n "$lat" && "$lat" != "null" && "$lat" != "0.0" ]]; then
        exif_args+=("-GPSLatitude=$lat")
        if [[ "$lat" == -* ]]; then
            exif_args+=("-GPSLatitudeRef=S")
        else
            exif_args+=("-GPSLatitudeRef=N")
        fi
    fi

    if [[ -n "$lon" && "$lon" != "null" && "$lon" != "0.0" ]]; then
        exif_args+=("-GPSLongitude=$lon")
        if [[ "$lon" == -* ]]; then
            exif_args+=("-GPSLongitudeRef=W")
        else
            exif_args+=("-GPSLongitudeRef=E")
        fi
    fi

    if [[ -n "$alt" && "$alt" != "null" && "$alt" != "0.0" ]]; then
        exif_args+=("-GPSAltitude=${alt#-}")
        if [[ "$alt" == -* ]]; then
            exif_args+=("-GPSAltitudeRef=1")
        else
            exif_args+=("-GPSAltitudeRef=0")
        fi
    fi

    if [[ -n "$desc" && "$desc" != "null" && "$desc" != "" ]]; then
        exif_args+=("-Description=$desc")
        exif_args+=("-ImageDescription=$desc")
    fi

    if [[ -n "$title" && "$title" != "null" && "$title" != "" ]]; then
        exif_args+=("-XPTitle=$title")
    fi

    if [[ -n "$device_source" ]]; then
        exif_args+=("-XMP:Source=$device_source")
    fi

    for person in "${people[@]}"; do
        exif_args+=("-XMP:PersonInImage=$person")
    done

    if [[ ${#exif_args[@]} -gt 0 ]]; then
        exiftool -overwrite_original "${exif_args[@]}" "$file" &>/dev/null
    fi
}

process_json() {
    local json_path="$1"
    local json_name
    json_name=$(basename "$json_path")
    local json_dir
    json_dir=$(dirname "$json_path")
    local dir_name
    dir_name=$(basename "$json_dir")

    # Read title (original media filename without any duplicate counter)
    local title
    title=$(jq -r '.title // empty' "$json_path" 2>/dev/null)
    [[ -z "$title" ]] && return 0

    # Must have a photoTakenTime to be a valid media sidecar
    local timestamp
    timestamp=$(jq -r '.photoTakenTime.timestamp // empty' "$json_path" 2>/dev/null)
    [[ -z "$timestamp" || "$timestamp" == "null" ]] && return 0

    # Extract trailing (N)(M)... counter sequence from the JSON stem if present
    # Handles both single (1) and double (1)(1) patterns
    local json_stem="${json_name%.json}"
    local counter=""
    if [[ "$json_stem" =~ (\([0-9]+\))+$ ]]; then
        counter="${BASH_REMATCH[0]}"
    fi

    # Construct media filename: insert counter before extension if present
    local media_name
    if [[ -n "$counter" ]]; then
        local t_stem="${title%.*}"
        local t_ext="${title##*.}"
        media_name="${t_stem}${counter}.${t_ext}"
    else
        media_name="$title"
    fi

    # Find the media file in dirs sharing the same name as the JSON's parent
    local media_path
    media_path=$(find_media_for_json "$media_name" "$dir_name")

    if [[ -z "$media_path" ]]; then
        echo "SKIP (no media found): $media_name"
        [[ $DEBUG -eq 1 ]] && echo "  DEBUG: json=$json_path | title=$media_name | no match in dir=$dir_name"
        return 0
    fi

    [[ $DEBUG -eq 1 ]] && echo "  DEBUG: json=$json_path | media=$media_path"

    local formatted_date
    formatted_date=$(date -d "@$timestamp" +"$TIMESTAMP_FORMAT" 2>/dev/null)
    if [[ -z "$formatted_date" ]]; then
        echo "SKIP (invalid date): $media_name"
        return 0
    fi

    local media_dir extension new_name new_path
    media_dir=$(dirname "$media_path")
    extension="${media_path##*.}"
    new_name="${formatted_date}.${extension}"
    new_path="${media_dir}/${new_name}"

    if [[ "$media_path" == "$new_path" ]]; then
        echo "SKIP (already named): $media_name"
        return 0
    fi

    if [[ -e "$new_path" ]]; then
        local c=1
        while [[ -e "${media_dir}/${formatted_date}_${c}.${extension}" ]]; do
            ((c++))
        done
        new_name="${formatted_date}_${c}.${extension}"
        new_path="${media_dir}/${new_name}"
    fi

    if [[ $DRY_RUN -eq 1 ]]; then
        echo "WOULD RENAME: $media_name -> $new_name"
    else
        if mv "$media_path" "$new_path"; then
            echo "RENAMED: $media_name -> $new_name"
            write_json_metadata "$new_path" "$json_path"
            rm "$json_path" && echo "  Deleted: $json_name"
        else
            echo "ERROR renaming: $media_name"
        fi
    fi
}

main() {
    if [[ $DRY_RUN -eq 1 ]]; then
        echo "DRY RUN MODE - No files will be renamed"
        echo "=========================================="
    fi

    echo "Processing: $TARGET_DIR"
    echo ""

    build_dir_cache

    local rename_count=0 skip_count=0
    while IFS= read -r -d '' json_file; do
        result=$(process_json "$json_file")
        [[ -n "$result" ]] && echo "$result"
        if grep -q "^RENAMED" <<< "$result"; then
            ((rename_count++))
        elif grep -q "^SKIP" <<< "$result"; then
            ((skip_count++))
        fi
    done < <(find "$TARGET_DIR" -type f -name "*.json" -print0 2>/dev/null)

    echo ""
    echo "=========================================="
    echo "Renamed: $rename_count  Skipped: $skip_count"

    if [[ $DRY_RUN -eq 1 ]]; then
        echo ""
        echo "This was a dry run. Use without --dry-run to actually rename files."
    fi
}

main
