#!/usr/bin/env bash
set -euo pipefail

xdg_config_home="${XDG_CONFIG_HOME:-$HOME/.config}"
cfg="$xdg_config_home/find-files/ignore-globs"
exclude_args=()
search_roots=()
name_filters=()

if [ -f "$cfg" ]; then
  while IFS= read -r pat || [ -n "$pat" ]; do
    [ -z "$pat" ] && continue
    case "$pat" in
      \#*) continue ;;
    esac
    exclude_args+=(--exclude "$pat")
  done < "$cfg"
fi

for arg in "$@"; do
  if [ -e "$arg" ]; then
    search_roots+=("$arg")
  else
    name_filters+=("$arg")
  fi
done

if [ "${#search_roots[@]}" -eq 0 ]; then
  search_roots=(.)
fi

base_args=(
  --type
  f
  --hidden
)

{
  fd . "${search_roots[@]}" "${base_args[@]}" "${exclude_args[@]}" 2>/dev/null
  fd --glob '*.env*' "${search_roots[@]}" "${base_args[@]}" --no-ignore "${exclude_args[@]}" 2>/dev/null
} | awk '
  BEGIN {
    for (i = 1; i < ARGC; i++) {
      filters[i] = tolower(ARGV[i])
    }
    ARGC = 1
  }
  {
    path = tolower($0)
    for (i in filters) {
      if (index(path, filters[i]) == 0) {
        next
      }
    }
    output = $0
    sub(/^\.\/+/, "", output)
    if (!seen[output]++) {
      print output
    }
  }
' "${name_filters[@]}"
