#!/bin/bash

VERSION="1.2.0"

usage() {
    cat << EOF
Usage: rename-by-date [OPTIONS] <directory>

Rename images and videos based on their timestamp metadata (EXIF date taken).
Only renames files that have valid date metadata.

Options:
    --dry-run, -n       Show what would be renamed without actually renaming
    --format <fmt>      Timestamp format (default: %Y%m%d_%H%M%S%-3f)
    --help, -h          Show this help message
    --version, -v       Show version information

Supported formats:
    Images: .jpg, .jpeg, .png, .gif, .bmp, .tiff, .webp, .dng, .heic
    Videos: .mp4, .mov, .avi, .mkv, .m4v, .3gp

Format specifiers (exiftool -d syntax):
    %Y %m %d %H %M %S   standard date/time components
    %-3f                 3-digit milliseconds (no decimal point), e.g. 528
    %3f                  3-digit milliseconds with decimal point, e.g. .528

Examples:
    rename-by-date --dry-run ~/Pictures
    rename-by-date --format "%Y-%m-%d_%H%M%S%-3f" ~/Downloads
    rename-by-date ~/Videos

Note:
    Date extraction priority:
    1. SubSecDateTimeOriginal (EXIF with milliseconds)
    2. DateTimeOriginal (EXIF)
    3. GPS timestamp
    4. CreationDate (QuickTime/MOV - local time with timezone)
    5. CreateDate
    6. ModifyDate
    7. File modification date (last resort)

    Files starting with ._ (macOS resource forks) will be skipped.
    Existing files with the same name will be avoided with numeric suffixes.

EOF
}

show_version() {
    echo "rename-by-date version $VERSION"
}

DRY_RUN=0
TIMESTAMP_FORMAT="%Y%m%d_%H%M%S%-3f"
TARGET_DIR=""

while [[ $# -gt 0 ]]; do
    case $1 in
        --dry-run|-n)
            DRY_RUN=1
            shift
            ;;
        --format)
            TIMESTAMP_FORMAT="$2"
            shift 2
            ;;
        --help|-h)
            usage
            exit 0
            ;;
        --version|-v)
            show_version
            exit 0
            ;;
        -*)
            echo "Error: Unknown option: $1"
            usage
            exit 1
            ;;
        *)
            if [[ -z "$TARGET_DIR" ]]; then
                TARGET_DIR="$1"
            else
                echo "Error: Multiple directories specified"
                usage
                exit 1
            fi
            shift
            ;;
    esac
done

if [[ -z "$TARGET_DIR" ]]; then
    echo "Error: No directory specified"
    usage
    exit 1
fi

if [[ ! -d "$TARGET_DIR" ]]; then
    echo "Error: Directory not found: $TARGET_DIR"
    exit 1
fi

if ! command -v exiftool &> /dev/null; then
    echo "Error: exiftool is required but not installed"
    exit 1
fi

# Case-insensitive file existence check (catches jpg vs JPG, etc.)
ci_exists() {
    local dir="$1"
    local name="$2"
    find "$dir" -maxdepth 1 -iname "$name" -print -quit 2>/dev/null | grep -q .
}

# Convert exiftool fractional-second specifiers to literal zeros for use with date(1)
# e.g. "%Y%m%d_%H%M%S%-3f" -> "%Y%m%d_%H%M%S000"
fmt_for_date() {
    printf '%s' "$1" | sed 's/%-\?[0-9]*f/000/g'
}

extract_date() {
    local file="$1"
    local formatted=""

    # 1. SubSecDateTimeOriginal (DateTimeOriginal + milliseconds; label is "Date/Time Original")
    formatted=$(exiftool -d "$TIMESTAMP_FORMAT" -SubSecDateTimeOriginal "$file" 2>/dev/null |
                grep "Date/Time Original" |
                head -1 |
                awk -F': ' '{print $2}' |
                grep -v "^0000" | head -1 || true)

    # 2. DateTimeOriginal (most accurate - when photo was taken)
    if [[ -z "$formatted" ]]; then
        formatted=$(exiftool -d "$TIMESTAMP_FORMAT" -DateTimeOriginal "$file" 2>/dev/null |
                    grep "Date/Time Original" |
                    head -1 |
                    awk -F': ' '{print $2}' |
                    grep -v "^0000" | head -1 || true)
    fi

    # 3. GPS timestamp (highly reliable, from satellites)
    if [[ -z "$formatted" ]]; then
        formatted=$(exiftool -d "$TIMESTAMP_FORMAT" -GPSDateTime "$file" 2>/dev/null |
                    grep "GPS Date/Time" |
                    head -1 |
                    awk -F': ' '{print $2}' |
                    grep -v "^0000" | head -1 || true)
    fi

    # 4. CreationDate (QuickTime/MOV - local time with timezone offset)
    if [[ -z "$formatted" ]]; then
        formatted=$(exiftool -d "$TIMESTAMP_FORMAT" -CreationDate "$file" 2>/dev/null |
                    grep "Creation Date" |
                    head -1 |
                    awk -F': ' '{print $2}' |
                    grep -v "^0000" | head -1 || true)
    fi

    # 5. SubSecCreateDate (CreateDate + milliseconds; label is "Create Date")
    if [[ -z "$formatted" ]]; then
        formatted=$(exiftool -d "$TIMESTAMP_FORMAT" -SubSecCreateDate "$file" 2>/dev/null |
                    grep "Create Date" |
                    head -1 |
                    awk -F': ' '{print $2}' |
                    grep -v "^0000" | head -1 || true)
    fi

    # 6. ModifyDate (EXIF metadata)
    if [[ -z "$formatted" ]]; then
        formatted=$(exiftool -d "$TIMESTAMP_FORMAT" -ModifyDate "$file" 2>/dev/null |
                    grep "Modify Date" |
                    head -1 |
                    awk -F': ' '{print $2}' |
                    grep -v "^0000" | head -1 || true)
    fi

    # 7. Last resort: file modification date (filesystem timestamp)
    if [[ -z "$formatted" ]]; then
        formatted=$(exiftool -d "$TIMESTAMP_FORMAT" -FileModifyDate "$file" 2>/dev/null |
                    grep "File Modification Date" |
                    head -1 |
                    awk -F': ' '{print $2}' |
                    grep -v "^0000" | head -1 || true)
    fi

    echo "$formatted"
}

process_file() {
    local file_path="$1"
    local dir_name base_name extension
    dir_name=$(dirname "$file_path")
    base_name=$(basename "$file_path")
    extension="${base_name##*.}"

    # Skip macOS resource forks (._filename) but allow extension-only files (.JPG, .PNG, etc)
    if [[ "$base_name" == ._* ]]; then
        return 0
    fi

    # Skip hidden dot files (but not extension-only files like .JPG)
    if [[ "$base_name" == .* ]] && [[ "$base_name" != ".$extension" ]]; then
        return 0
    fi

    # Skip JSON metadata files
    if [[ "$base_name" == *.json ]]; then
        return 0
    fi

    local formatted_date
    formatted_date=$(extract_date "$file_path")

    if [[ -z "$formatted_date" ]]; then
        echo "SKIP (no date): $base_name"
        return 0
    fi

    local new_name="${formatted_date}.${extension}"
    local new_path="${dir_name}/${new_name}"

    if [[ "$file_path" == "$new_path" ]]; then
        echo "SKIP (already named): $base_name"
        return 0
    fi

    if ci_exists "$dir_name" "$new_name"; then
        local counter=1
        while ci_exists "$dir_name" "${formatted_date}_${counter}.${extension}"; do
            ((counter++))
        done
        new_name="${formatted_date}_${counter}.${extension}"
        new_path="${dir_name}/${new_name}"
    fi

    if [[ $DRY_RUN -eq 1 ]]; then
        echo "WOULD RENAME: $base_name -> $new_name"
    else
        if mv "$file_path" "$new_path"; then
            echo "RENAMED: $base_name -> $new_name"
        else
            echo "ERROR renaming: $base_name"
        fi
    fi
}

main() {
    if [[ $DRY_RUN -eq 1 ]]; then
        echo "DRY RUN MODE - No files will be renamed"
        echo "=========================================="
    fi

    echo "Processing files in: $TARGET_DIR"
    echo ""

    local file_count=0
    while IFS= read -r -d '' file; do
        ((file_count++))
        process_file "$file"
    done < <(find "$TARGET_DIR" -type f ! -name "._*" \( \
        -iname "*.jpg" -o -iname "*.jpeg" -o \
        -iname "*.png" -o -iname "*.gif" -o \
        -iname "*.bmp" -o -iname "*.tiff" -o -iname "*.webp" -o -iname "*.dng" -o -iname "*.heic" -o \
        -iname "*.mp4" -o -iname "*.mov" -o -iname "*.avi" -o \
        -iname "*.mkv" -o -iname "*.m4v" -o -iname "*.3gp" \
    \) -print0)

    echo ""
    echo "=========================================="
    echo "Media files processed: $file_count"

    if [[ $DRY_RUN -eq 1 ]]; then
        echo ""
        echo "This was a dry run. Use without --dry-run to actually rename files."
    fi
}

main
