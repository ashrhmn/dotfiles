#!/bin/bash

set -e

VERSION="2.0.0"
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/gh-agent"
CONFIG_FILE="$CONFIG_DIR/.config.json"
LOG_DIR="$CONFIG_DIR/logs"
WORKTREE_DIR="$HOME/.worktrees"

usage() {
    local cmd
    cmd=$(basename "$0")
    cat << EOF
Usage: $cmd [COMMAND] [PATH]

Automated issue resolver that monitors git repositories and uses AI Agent to solve issues in dedicated git worktrees.

Commands:
    add [PATH]          Add directory to watch list (. for current directory)
    remove [PATH]       Remove directory from watch list
    list                List all watched directories
    dry-run [PATH]      Preview planned issue handling without making changes
    start [--codex]     Start monitoring (runs forever, checks every 5 minutes)
    logs                Show recent log files
    version             Show version information

Start options:
    --claude            Use Claude for the start command (default)
    --codex             Use Codex for the start command
    --dry-run           Preview actions only; never pull, create worktrees, or run agents

General options:
    -h, --help          Show this help message
    -v, --version       Show version information

Examples:
    $cmd add .                  Add current directory
    $cmd add /path/to/repo      Add specific directory
    $cmd remove .               Remove current directory
    $cmd list                   Show all watched directories
    $cmd dry-run                Preview one immediate pass for all watched directories
    $cmd dry-run .              Preview one immediate pass for the current repository
    $cmd start                  Start the monitoring service with Claude
    $cmd start --codex          Start the monitoring service with Codex
    $cmd start --dry-run        Run one immediate preview pass and exit
    $cmd logs                   List recent log files

Configuration:
    Directories are stored in: $CONFIG_FILE
    Logs are stored in: $LOG_DIR
EOF
}

ensure_config() {
    mkdir -p "$CONFIG_DIR"
    mkdir -p "$LOG_DIR"
    mkdir -p "$WORKTREE_DIR"
    if [[ ! -f "$CONFIG_FILE" ]]; then
        echo '{"dirs":[]}' > "$CONFIG_FILE"
    fi
}

get_absolute_path() {
    local path="$1"
    if [[ "$path" == "." ]]; then
        pwd
    elif [[ "$path" == /* ]]; then
        echo "$path"
    else
        echo "$(pwd)/$path"
    fi
}

is_git_repository() {
    local path="$1"
    git -C "$path" rev-parse --git-dir >/dev/null 2>&1
}

is_working_tree_dirty() {
    local path="$1"
    [[ -n "$(git -C "$path" status --porcelain 2>/dev/null)" ]]
}

sanitize_path_component() {
    local value="$1"

    value=$(echo "$value" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9._-]+/-/g; s/^-+//; s/-+$//; s/-+/-/g')

    if [[ -z "$value" ]]; then
        value="unknown"
    fi

    echo "$value"
}

slugify_branch_component() {
    local value="$1"

    value=$(echo "$value" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//; s/-+/-/g')

    if [[ -z "$value" ]]; then
        value="work"
    fi

    echo "$value"
}

find_worktree_for_branch() {
    local repo_dir="$1"
    local branch="$2"

    git -C "$repo_dir" worktree list --porcelain 2>/dev/null | awk -v target_branch="refs/heads/$branch" '
        /^worktree / { worktree_path = substr($0, 10) }
        /^branch / && $2 == target_branch { print worktree_path; exit }
    '
}

has_upstream_branch() {
    local path="$1"
    git -C "$path" rev-parse --abbrev-ref --symbolic-full-name '@{upstream}' >/dev/null 2>&1
}

pull_fast_forward() {
    local path="$1"
    git -C "$path" pull --ff-only
}

get_repo_owner_and_name() {
    local repo_dir="$1"
    local remote_url repo_full_name repo_owner repo_name

    remote_url=$(git -C "$repo_dir" config --get remote.origin.url 2>/dev/null || true)
    if [[ -z "$remote_url" ]]; then
        return 1
    fi

    repo_full_name=$(echo "$remote_url" | sed -E 's#\.git$##; s#^[^:]+://##; s#^[^@]+@##; s#^[^:/]+[:/]##')
    if [[ "$repo_full_name" != */* ]]; then
        return 1
    fi

    repo_owner=${repo_full_name%%/*}
    repo_name=${repo_full_name#*/}

    repo_owner=$(sanitize_path_component "$repo_owner")
    repo_name=$(sanitize_path_component "$repo_name")

    if [[ -z "$repo_owner" ]] || [[ -z "$repo_name" ]]; then
        return 1
    fi

    echo "$repo_owner/$repo_name"
}

build_issue_thread_context() {
    local repo_full_name="$1"
    local issue_number="$2"
    local issue_details issue_body issue_comments

    if ! issue_details=$(gh issue view "$issue_number" --repo "$repo_full_name" --json body,comments 2>/dev/null); then
        return 1
    fi

    issue_body=$(printf '%s' "$issue_details" | jq -r '.body // ""')
    issue_comments=$(printf '%s' "$issue_details" | jq -r '
        (.comments // [])
        | if length == 0 then
            "No issue comments yet."
          else
            map(
                "Comment by @\(.author.login // "unknown") on \(.createdAt // "unknown time"):\n\(.body // "")"
            ) | join("\n\n")
          end
    ')

    cat <<EOF
Issue body:
$issue_body

Issue comments:
$issue_comments
EOF
}

get_current_gh_login() {
    gh api user --jq '.login' 2>/dev/null
}

get_issue_runtime_snapshot() {
    local repo_full_name="$1"
    local issue_number="$2"

    gh issue view "$issue_number" --repo "$repo_full_name" --json state,comments 2>/dev/null
}

count_issue_comments_from_snapshot() {
    local issue_snapshot="$1"

    printf '%s' "$issue_snapshot" | jq -r '(.comments // []) | length'
}

count_issue_comments_by_author_from_snapshot() {
    local issue_snapshot="$1"
    local author_login="$2"

    printf '%s' "$issue_snapshot" | jq -r --arg author_login "$author_login" '
        (.comments // [])
        | map(select(.author.login == $author_login))
        | length
    '
}

determine_worktree_plan() {
    local repo_dir="$1"
    local branch_name="$2"
    local worktree_path="$3"

    local existing_branch_worktree
    existing_branch_worktree=$(find_worktree_for_branch "$repo_dir" "$branch_name")

    if [[ -n "$existing_branch_worktree" ]] && [[ "$existing_branch_worktree" != "$worktree_path" ]]; then
        echo "skip:branch checked out in another worktree:$existing_branch_worktree"
        return 0
    fi

    if [[ -e "$worktree_path" ]] && [[ -z "$existing_branch_worktree" ]]; then
        echo "skip:path exists but is not a registered worktree:$worktree_path"
        return 0
    fi

    if [[ "$existing_branch_worktree" == "$worktree_path" ]]; then
        echo "reuse:existing worktree:$worktree_path"
        return 0
    fi

    if git -C "$repo_dir" show-ref --verify --quiet "refs/heads/$branch_name"; then
        echo "create:existing local branch:$branch_name"
        return 0
    fi

    if git -C "$repo_dir" ls-remote --exit-code --heads origin "$branch_name" >/dev/null 2>&1; then
        echo "create:remote branch:origin/$branch_name"
        return 0
    fi

    echo "create:new branch:HEAD"
}

get_pr_count_for_branch() {
    local repo_full_name="$1"
    local branch_name="$2"
    local pr_json

    if ! pr_json=$(gh pr list --repo "$repo_full_name" --head "$branch_name" --state all --json number 2>/dev/null); then
        return 1
    fi

    printf '%s' "$pr_json" | jq -r 'length'
}

get_remote_branch_sha() {
    local repo_dir="$1"
    local branch_name="$2"

    git -C "$repo_dir" ls-remote --heads origin "$branch_name" 2>/dev/null | awk 'NR == 1 { print $1 }'
}

get_local_head_sha() {
    local repo_dir="$1"

    git -C "$repo_dir" rev-parse HEAD 2>/dev/null
}

get_commits_ahead_of_base() {
    local repo_dir="$1"
    local base_branch="$2"

    git -C "$repo_dir" rev-list --count "$base_branch..HEAD" 2>/dev/null
}

validate_agent_outcome() {
    local worktree_path="$1"
    local repo_full_name="$2"
    local issue_number="$3"
    local branch_name="$4"
    local base_branch="$5"
    local gh_login="$6"
    local issue_agent_comments_before="$7"
    local pr_count_before="$8"
    local notification_file="$9"

    local issue_snapshot_after issue_state_after pr_count_after
    local issue_agent_comments_after local_head_sha remote_branch_sha
    local commits_ahead_of_base worktree_clean is_remote_synced
    local validation_flow validation_message

    if ! issue_snapshot_after=$(get_issue_runtime_snapshot "$repo_full_name" "$issue_number"); then
        validation_message="Post-run validation failed: could not fetch issue state for #$issue_number."
        echo "$validation_message"
        printf '\n%s\n' "$validation_message" >> "$notification_file"
        return 1
    fi

    issue_state_after=$(printf '%s' "$issue_snapshot_after" | jq -r '.state // ""')
    issue_agent_comments_after=$(count_issue_comments_by_author_from_snapshot "$issue_snapshot_after" "$gh_login")

    if ! pr_count_after=$(get_pr_count_for_branch "$repo_full_name" "$branch_name"); then
        validation_message="Post-run validation failed: could not fetch PR state for branch $branch_name."
        echo "$validation_message"
        printf '\n%s\n' "$validation_message" >> "$notification_file"
        return 1
    fi

    local_head_sha=$(get_local_head_sha "$worktree_path")
    remote_branch_sha=$(get_remote_branch_sha "$worktree_path" "$branch_name")
    commits_ahead_of_base=$(get_commits_ahead_of_base "$worktree_path" "$base_branch")

    if is_working_tree_dirty "$worktree_path"; then
        worktree_clean="no"
    else
        worktree_clean="yes"
    fi

    if [[ -n "$remote_branch_sha" ]] && [[ "$remote_branch_sha" == "$local_head_sha" ]]; then
        is_remote_synced="yes"
    else
        is_remote_synced="no"
    fi

    if [[ "$worktree_clean" != "yes" ]]; then
        validation_message="Post-run validation failed: worktree is still dirty after agent run."
        echo "$validation_message"
        printf '\n%s\n' "$validation_message" >> "$notification_file"
        return 1
    fi

    if [[ "$issue_state_after" == "CLOSED" ]] && (( pr_count_after > 0 )); then
        if [[ "$is_remote_synced" != "yes" ]]; then
            validation_message="Post-run validation failed: success flow requires the branch to be pushed, but origin/$branch_name does not match local HEAD."
            echo "$validation_message"
            printf '\n%s\n' "$validation_message" >> "$notification_file"
            return 1
        fi

        validation_flow="success"
        validation_message="Post-run validation passed: success flow confirmed with pushed branch, PR present, and issue closed."
    elif [[ "$issue_state_after" == "CLOSED" ]] && (( pr_count_after == 0 )) && (( issue_agent_comments_after > issue_agent_comments_before )); then
        if (( commits_ahead_of_base > 0 )) && [[ "$is_remote_synced" != "yes" ]]; then
            validation_message="Post-run validation failed: blocker flow detected, but branch changes were not pushed to origin/$branch_name."
            echo "$validation_message"
            printf '\n%s\n' "$validation_message" >> "$notification_file"
            return 1
        fi

        validation_flow="blocker"
        validation_message="Post-run validation passed: blocker flow confirmed with issue comment, no PR, and issue closed."
    else
        validation_message="Post-run validation failed: neither a valid success flow nor a valid blocker flow was completed."
        echo "$validation_message"
        printf '\n%s\n' "$validation_message" >> "$notification_file"
        return 1
    fi

    {
        printf '\n==> Post-run validation\n'
        printf 'Flow: %s\n' "$validation_flow"
        printf 'Issue state: %s\n' "$issue_state_after"
        printf 'PR count before/after: %s -> %s\n' "$pr_count_before" "$pr_count_after"
        printf 'Agent issue comments before/after: %s -> %s\n' "$issue_agent_comments_before" "$issue_agent_comments_after"
        printf 'Worktree clean: %s\n' "$worktree_clean"
        printf 'Remote synced to local HEAD: %s\n' "$is_remote_synced"
        printf '%s\n' "$validation_message"
    } | tee -a "$notification_file"
}

prepare_worktree() {
    local repo_dir="$1"
    local branch_name="$2"
    local worktree_path="$3"
    local base_ref="$4"

    mkdir -p "$(dirname "$worktree_path")"
    git -C "$repo_dir" worktree prune >/dev/null 2>&1 || true

    local existing_branch_worktree
    existing_branch_worktree=$(find_worktree_for_branch "$repo_dir" "$branch_name")

    if [[ -n "$existing_branch_worktree" ]] && [[ "$existing_branch_worktree" != "$worktree_path" ]]; then
        echo "Skipping (branch already checked out in another worktree): $existing_branch_worktree"
        return 1
    fi

    if [[ -e "$worktree_path" ]] && [[ -z "$existing_branch_worktree" ]]; then
        echo "Skipping (worktree path already exists but is not registered): $worktree_path"
        return 1
    fi

    if [[ "$existing_branch_worktree" == "$worktree_path" ]]; then
        echo "Reusing existing worktree: $worktree_path"
        return 0
    fi

    if git -C "$repo_dir" show-ref --verify --quiet "refs/heads/$branch_name"; then
        echo "Creating worktree from existing local branch: $branch_name"
        if ! git -C "$repo_dir" worktree add "$worktree_path" "$branch_name"; then
            echo "Skipping (failed to create worktree from local branch): $branch_name"
            return 1
        fi
        return 0
    fi

    if git -C "$repo_dir" ls-remote --exit-code --heads origin "$branch_name" >/dev/null 2>&1; then
        echo "Creating worktree from remote branch: origin/$branch_name"
        if ! git -C "$repo_dir" worktree add --track -b "$branch_name" "$worktree_path" "origin/$branch_name"; then
            echo "Skipping (failed to create worktree from remote branch): origin/$branch_name"
            return 1
        fi
        return 0
    fi

    echo "Creating worktree and branch: $branch_name"
    if ! git -C "$repo_dir" worktree add -b "$branch_name" "$worktree_path" "$base_ref"; then
        echo "Skipping (failed to create new worktree branch): $branch_name"
        return 1
    fi
}

print_dry_run_summary() {
    local dir="$1"
    local repo_full_name="$2"
    local issue_number="$3"
    local branch_name="$4"
    local worktree_path="$5"
    local worktree_plan="$6"
    local log_file="$7"
    local gh_login="$8"
    local issue_snapshot="$9"
    local issue_thread_context="${10}"

    local issue_state comment_count my_comment_count pr_count
    local worktree_action worktree_detail worktree_target

    issue_state=$(printf '%s' "$issue_snapshot" | jq -r '.state // "UNKNOWN"' 2>/dev/null)
    comment_count=$(count_issue_comments_from_snapshot "$issue_snapshot")
    my_comment_count=$(count_issue_comments_by_author_from_snapshot "$issue_snapshot" "$gh_login")
    pr_count=$(get_pr_count_for_branch "$repo_full_name" "$branch_name" 2>/dev/null || echo "unknown")

    IFS=':' read -r worktree_action worktree_detail worktree_target <<< "$worktree_plan"

    echo "Dry run summary:"
    echo "  Repository: $repo_full_name"
    echo "  Planned branch: $branch_name"
    echo "  Planned worktree path: $worktree_path"
    case "$worktree_action" in
        reuse)
            echo "  Worktree action: reuse existing worktree ($worktree_target)"
            ;;
        create)
            echo "  Worktree action: create worktree from $worktree_detail ($worktree_target)"
            ;;
        skip)
            echo "  Worktree action: would skip real run because $worktree_detail ($worktree_target)"
            ;;
        *)
            echo "  Worktree action: unknown"
            ;;
    esac
    echo "  Planned log file: $log_file"
    echo "  GitHub issue state: $issue_state"
    echo "  Total issue comments: $comment_count"
    echo "  Existing comments by @$gh_login: $my_comment_count"
    echo "  Existing PR count for branch: $pr_count"
    echo "  Issue details fetched: yes"
    echo "  Agent invocation: skipped in dry-run mode"
    if [[ -n "$issue_thread_context" ]]; then
        echo "  Issue snapshot preview:"
        print_preview_block "$issue_thread_context" 8 800
    fi
}

add_directory() {
    local path="$1"
    if [[ -z "$path" ]]; then
        echo "Error: Path required"
        echo "Usage: $(basename "$0") add [PATH]"
        exit 1
    fi

    ensure_config
    local abs_path
    abs_path=$(get_absolute_path "$path")

    if [[ ! -d "$abs_path" ]]; then
        echo "Error: Directory does not exist: $abs_path"
        exit 1
    fi

    if ! is_git_repository "$abs_path"; then
        echo "Error: Not a git repository: $abs_path"
        exit 1
    fi

    local existing_dirs
    existing_dirs=$(jq -r '.dirs[]' "$CONFIG_FILE" 2>/dev/null || echo "")

    if echo "$existing_dirs" | grep -Fxq "$abs_path"; then
        echo "Directory already added: $abs_path"
        exit 0
    fi

    jq --arg dir "$abs_path" '.dirs += [$dir]' "$CONFIG_FILE" > "$CONFIG_FILE.tmp"
    mv "$CONFIG_FILE.tmp" "$CONFIG_FILE"
    echo "Added directory: $abs_path"
}

remove_directory() {
    local path="$1"
    if [[ -z "$path" ]]; then
        echo "Error: Path required"
        echo "Usage: $(basename "$0") remove [PATH]"
        exit 1
    fi

    ensure_config
    local abs_path
    abs_path=$(get_absolute_path "$path")

    jq --arg dir "$abs_path" '.dirs = (.dirs - [$dir])' "$CONFIG_FILE" > "$CONFIG_FILE.tmp"
    mv "$CONFIG_FILE.tmp" "$CONFIG_FILE"
    echo "Removed directory: $abs_path"
}

list_directories() {
    ensure_config
    local dirs
    dirs=$(jq -r '.dirs[]' "$CONFIG_FILE" 2>/dev/null)

    if [[ -z "$dirs" ]]; then
        echo "No directories configured"
        echo "Use '$(basename "$0") add [PATH]' to add directories"
    else
        echo "Watched directories:"
        echo "$dirs" | while read -r dir; do
            echo "  $dir"
        done
    fi
}

list_logs() {
    ensure_config

    if [[ ! -d "$LOG_DIR" ]] || [[ -z "$(ls -A "$LOG_DIR" 2>/dev/null)" ]]; then
        echo "No log files found"
        echo "Logs will be created in: $LOG_DIR"
        return
    fi

    echo "Recent log files (latest first):"
    ls -lt "$LOG_DIR"/*.json 2>/dev/null | head -20 | while read -r line; do
        local file
        file=$(echo "$line" | awk '{print $NF}')
        local size
        size=$(echo "$line" | awk '{print $5}')
        local date
        date=$(echo "$line" | awk '{print $6, $7, $8}')
        echo "  $(basename "$file") - $size bytes - $date"
    done

    echo ""
    echo "Log directory: $LOG_DIR"
}

truncate_single_line() {
    local text="$1"
    local max_chars="${2:-160}"

    text=$(echo "$text" | tr '\n' ' ' | tr '\r' ' ' | sed -E 's/[[:space:]]+/ /g; s/^ //; s/ $//')

    if (( ${#text} > max_chars )); then
        echo "${text:0:max_chars-3}..."
    else
        echo "$text"
    fi
}

print_preview_block() {
    local text="$1"
    local max_lines="${2:-8}"
    local max_chars="${3:-1200}"
    local line_count=0
    local preview

    preview=$(printf '%s\n' "$text" | sed '/^<system-reminder>/,/^<\/system-reminder>/d')
    preview=${preview//$'\r'/}

    if [[ -z "$preview" ]]; then
        return
    fi

    if (( ${#preview} > max_chars )); then
        preview="${preview:0:max_chars}"$'\n...'
    fi

    while IFS= read -r preview_line; do
        ((line_count += 1))
        if (( line_count > max_lines )); then
            echo "      ..."
            break
        fi
        echo "      $preview_line"
    done <<< "$preview"
}

format_duration_ms() {
    local duration_ms="$1"

    if [[ -z "$duration_ms" ]] || [[ "$duration_ms" == "null" ]]; then
        return
    fi

    awk -v ms="$duration_ms" 'BEGIN { printf "%.1fs", ms / 1000 }'
}

format_epoch_timestamp() {
    local epoch="$1"

    if [[ -z "$epoch" ]] || [[ "$epoch" == "null" ]]; then
        return
    fi

    date -d "@$epoch" '+%Y-%m-%d %H:%M:%S' 2>/dev/null || echo "$epoch"
}

summarize_tool_input() {
    local tool_name="$1"
    local input_json="$2"
    local summary=""

    case "$tool_name" in
        Bash)
            summary=$(echo "$input_json" | jq -r '.command // empty' 2>/dev/null)
            ;;
        Read)
            local file_path offset limit
            file_path=$(echo "$input_json" | jq -r '.file_path // empty' 2>/dev/null)
            offset=$(echo "$input_json" | jq -r '.offset // empty' 2>/dev/null)
            limit=$(echo "$input_json" | jq -r '.limit // empty' 2>/dev/null)
            summary="$file_path"
            if [[ -n "$offset" ]]; then
                summary="$summary (offset $offset"
                if [[ -n "$limit" ]]; then
                    summary="$summary, limit $limit"
                fi
                summary="$summary)"
            elif [[ -n "$limit" ]]; then
                summary="$summary (limit $limit)"
            fi
            ;;
        Edit)
            local edit_path
            edit_path=$(echo "$input_json" | jq -r '.file_path // empty' 2>/dev/null)
            summary="$edit_path"
            ;;
        MultiEdit)
            local multi_edit_path
            multi_edit_path=$(echo "$input_json" | jq -r '.file_path // empty' 2>/dev/null)
            summary="$multi_edit_path"
            ;;
        Write)
            summary=$(echo "$input_json" | jq -r '.file_path // empty' 2>/dev/null)
            ;;
        Grep)
            local pattern grep_path
            pattern=$(echo "$input_json" | jq -r '.pattern // empty' 2>/dev/null)
            grep_path=$(echo "$input_json" | jq -r '.path // empty' 2>/dev/null)
            summary="pattern=$(truncate_single_line "$pattern" 80)"
            if [[ -n "$grep_path" ]]; then
                summary="$summary path=$grep_path"
            fi
            ;;
        Glob)
            local pattern glob_path
            pattern=$(echo "$input_json" | jq -r '.pattern // empty' 2>/dev/null)
            glob_path=$(echo "$input_json" | jq -r '.path // empty' 2>/dev/null)
            summary="pattern=$(truncate_single_line "$pattern" 80)"
            if [[ -n "$glob_path" ]]; then
                summary="$summary path=$glob_path"
            fi
            ;;
        LS)
            summary=$(echo "$input_json" | jq -r '.path // empty' 2>/dev/null)
            ;;
        *)
            summary=$(echo "$input_json" | jq -c '.' 2>/dev/null)
            ;;
    esac

    truncate_single_line "$summary" 200
}

format_claude_json_stream() {
    local current_turn=0
    local line_json
    local last_assistant_text=""
    local -A tool_names=()
    local -A tool_summaries=()

    while IFS= read -r line; do
        if [[ -z "$line" ]]; then
            continue
        fi

        if ! echo "$line" | jq -e . >/dev/null 2>&1; then
            echo "!! Raw output"
            print_preview_block "$line" 8 1200
            continue
        fi

        local msg_type
        msg_type=$(echo "$line" | jq -r '.type // empty' 2>/dev/null)

        case "$msg_type" in
            system)
                local subtype
                subtype=$(echo "$line" | jq -r '.subtype // empty' 2>/dev/null)
                if [[ "$subtype" == "init" ]]; then
                    local cwd model session_id permission_mode output_style
                    cwd=$(echo "$line" | jq -r '.cwd // empty' 2>/dev/null)
                    model=$(echo "$line" | jq -r '.model // empty' 2>/dev/null)
                    session_id=$(echo "$line" | jq -r '.session_id // empty' 2>/dev/null)
                    permission_mode=$(echo "$line" | jq -r '.permissionMode // empty' 2>/dev/null)
                    output_style=$(echo "$line" | jq -r '(.output_style | if type == "object" then .name else . end) // empty' 2>/dev/null)
                    echo "==> Initialized in: $cwd"
                    echo "==> Model: $model"
                    if [[ -n "$session_id" ]]; then
                        echo "==> Session: $session_id"
                    fi
                    if [[ -n "$permission_mode" ]]; then
                        echo "==> Permissions: $permission_mode"
                    fi
                    if [[ -n "$output_style" ]]; then
                        echo "==> Output style: $output_style"
                    fi
                fi
                ;;
            assistant)
                while IFS= read -r line_json; do
                    local content_type
                    content_type=$(echo "$line_json" | jq -r '.type // empty' 2>/dev/null)

                    case "$content_type" in
                        text)
                            local content
                            content=$(echo "$line_json" | jq -r '.text // empty' 2>/dev/null)
                            if [[ -n "$content" ]]; then
                                current_turn=$((current_turn + 1))
                                last_assistant_text="$content"
                                echo ""
                                echo "--- Turn $current_turn ---"
                                echo "$content"
                            fi
                            ;;
                        tool_use)
                            local tool_id tool_name input_json tool_summary
                            tool_id=$(echo "$line_json" | jq -r '.id // empty' 2>/dev/null)
                            tool_name=$(echo "$line_json" | jq -r '.name // empty' 2>/dev/null)
                            input_json=$(echo "$line_json" | jq -c '.input // {}' 2>/dev/null)
                            tool_summary=$(summarize_tool_input "$tool_name" "$input_json")

                            if [[ -n "$tool_id" ]]; then
                                tool_names["$tool_id"]="$tool_name"
                                tool_summaries["$tool_id"]="$tool_summary"
                            fi

                            echo "--> [$tool_name] $tool_summary"
                            ;;
                    esac
                done < <(echo "$line" | jq -c '.message.content[]?' 2>/dev/null)
                ;;
            user)
                local tool_result_json tool_id tool_name tool_summary tool_status tool_content tool_stderr
                tool_result_json=$(echo "$line" | jq -c 'first(.message.content[]? | select(.type == "tool_result")) // empty' 2>/dev/null)

                if [[ -z "$tool_result_json" ]]; then
                    continue
                fi

                tool_id=$(echo "$tool_result_json" | jq -r '.tool_use_id // empty' 2>/dev/null)
                tool_name="${tool_names[$tool_id]:-tool}"
                tool_summary="${tool_summaries[$tool_id]:-}"
                tool_status=$(echo "$tool_result_json" | jq -r 'if .is_error == true then "error" else "ok" end' 2>/dev/null)
                tool_content=$(echo "$tool_result_json" | jq -r '.content // empty' 2>/dev/null)
                tool_stderr=$(echo "$line" | jq -r '.tool_use_result.stderr // empty' 2>/dev/null)

                echo "<-- [$tool_name] $tool_status"
                if [[ -n "$tool_summary" ]]; then
                    echo "    $tool_summary"
                fi
                if [[ -n "$tool_content" ]]; then
                    echo "    Output:"
                    print_preview_block "$tool_content" 8 1200
                fi
                if [[ -n "$tool_stderr" ]]; then
                    echo "    STDERR:"
                    print_preview_block "$tool_stderr" 8 1200
                fi
                ;;
            rate_limit_event)
                local rate_limit_status rate_limit_type resets_at overage_resets_at is_using_overage
                rate_limit_status=$(echo "$line" | jq -r '.rate_limit_info.status // empty' 2>/dev/null)
                rate_limit_type=$(echo "$line" | jq -r '.rate_limit_info.rateLimitType // empty' 2>/dev/null)
                resets_at=$(echo "$line" | jq -r '.rate_limit_info.resetsAt // empty' 2>/dev/null)
                overage_resets_at=$(echo "$line" | jq -r '.rate_limit_info.overageResetsAt // empty' 2>/dev/null)
                is_using_overage=$(echo "$line" | jq -r '.rate_limit_info.isUsingOverage // false' 2>/dev/null)

                echo "==> Rate limit: $rate_limit_status ($rate_limit_type)"
                if [[ -n "$resets_at" ]]; then
                    echo "    Resets at: $(format_epoch_timestamp "$resets_at")"
                fi
                if [[ -n "$overage_resets_at" ]]; then
                    echo "    Overage resets at: $(format_epoch_timestamp "$overage_resets_at")"
                fi
                echo "    Using overage: $is_using_overage"
                ;;
            result)
                local subtype result stop_reason duration_ms duration_api_ms total_cost input_tokens output_tokens cache_read_tokens cache_write_tokens
                subtype=$(echo "$line" | jq -r '.subtype // empty' 2>/dev/null)
                result=$(echo "$line" | jq -r '.result // empty' 2>/dev/null)
                stop_reason=$(echo "$line" | jq -r '.stop_reason // empty' 2>/dev/null)
                duration_ms=$(echo "$line" | jq -r '.duration_ms // empty' 2>/dev/null)
                duration_api_ms=$(echo "$line" | jq -r '.duration_api_ms // empty' 2>/dev/null)
                total_cost=$(echo "$line" | jq -r '.total_cost_usd // empty' 2>/dev/null)
                input_tokens=$(echo "$line" | jq -r '.usage.input_tokens // empty' 2>/dev/null)
                output_tokens=$(echo "$line" | jq -r '.usage.output_tokens // empty' 2>/dev/null)
                cache_read_tokens=$(echo "$line" | jq -r '.usage.cache_read_input_tokens // empty' 2>/dev/null)
                cache_write_tokens=$(echo "$line" | jq -r '.usage.cache_creation_input_tokens // empty' 2>/dev/null)
                echo ""
                echo "==> Result: $subtype"
                if [[ -n "$stop_reason" ]]; then
                    echo "    Stop reason: $stop_reason"
                fi
                if [[ -n "$duration_ms" ]]; then
                    echo "    Duration: $(format_duration_ms "$duration_ms") total"
                    if [[ -n "$duration_api_ms" ]]; then
                        echo "    API time: $(format_duration_ms "$duration_api_ms")"
                    fi
                fi
                if [[ -n "$total_cost" ]]; then
                    echo "    Cost: \$${total_cost}"
                fi
                if [[ -n "$input_tokens" ]] || [[ -n "$output_tokens" ]] || [[ -n "$cache_read_tokens" ]] || [[ -n "$cache_write_tokens" ]]; then
                    echo "    Tokens: input=${input_tokens:-0}, output=${output_tokens:-0}, cache_read=${cache_read_tokens:-0}, cache_write=${cache_write_tokens:-0}"
                fi
                if [[ -n "$result" ]] && [[ "$result" != "$last_assistant_text" ]]; then
                    echo "$result"
                fi
                ;;
        esac
    done
}

format_codex_json_stream() {
    local current_turn=0

    while IFS= read -r line; do
        if [[ -z "$line" ]]; then
            continue
        fi

        if ! echo "$line" | jq -e . >/dev/null 2>&1; then
            echo "!! Raw output"
            print_preview_block "$line" 8 1200
            continue
        fi

        local event_type
        event_type=$(echo "$line" | jq -r '.type // empty' 2>/dev/null)

        case "$event_type" in
            thread.started)
                local thread_id
                thread_id=$(echo "$line" | jq -r '.thread_id // empty' 2>/dev/null)
                if [[ -n "$thread_id" ]]; then
                    echo "==> Thread: $thread_id"
                fi
                ;;
            turn.started)
                current_turn=$((current_turn + 1))
                echo ""
                echo "--- Turn $current_turn ---"
                ;;
            item.started)
                local started_type
                started_type=$(echo "$line" | jq -r '.item.type // empty' 2>/dev/null)

                case "$started_type" in
                    command_execution)
                        local started_command
                        started_command=$(echo "$line" | jq -r '.item.command // empty' 2>/dev/null)
                        echo "--> [exec] $(truncate_single_line "$started_command" 200)"
                        ;;
                    mcp_tool_call)
                        local started_server started_tool started_args
                        started_server=$(echo "$line" | jq -r '.item.server // empty' 2>/dev/null)
                        started_tool=$(echo "$line" | jq -r '.item.tool // empty' 2>/dev/null)
                        started_args=$(echo "$line" | jq -c '.item.arguments // {}' 2>/dev/null)
                        echo "--> [mcp:$started_server/$started_tool] $(truncate_single_line "$started_args" 200)"
                        ;;
                    collab_tool_call)
                        local started_collab_tool
                        started_collab_tool=$(echo "$line" | jq -r '.item.tool // empty' 2>/dev/null)
                        echo "--> [collab:$started_collab_tool]"
                        ;;
                    web_search)
                        local started_query
                        started_query=$(echo "$line" | jq -r '.item.query // empty' 2>/dev/null)
                        echo "--> [web_search] $(truncate_single_line "$started_query" 200)"
                        ;;
                    todo_list)
                        echo "==> Plan"
                        while IFS=$'\t' read -r completed text; do
                            if [[ -z "$text" ]]; then
                                continue
                            fi
                            if [[ "$completed" == "true" ]]; then
                                echo "    [x] $text"
                            else
                                echo "    [ ] $text"
                            fi
                        done < <(echo "$line" | jq -r '.item.items[]? | "\(.completed)\t\(.text)"' 2>/dev/null)
                        ;;
                esac
                ;;
            item.updated)
                local updated_type
                updated_type=$(echo "$line" | jq -r '.item.type // empty' 2>/dev/null)

                if [[ "$updated_type" == "todo_list" ]]; then
                    echo "==> Plan updated"
                    while IFS=$'\t' read -r completed text; do
                        if [[ -z "$text" ]]; then
                            continue
                        fi
                        if [[ "$completed" == "true" ]]; then
                            echo "    [x] $text"
                        else
                            echo "    [ ] $text"
                        fi
                    done < <(echo "$line" | jq -r '.item.items[]? | "\(.completed)\t\(.text)"' 2>/dev/null)
                fi
                ;;
            item.completed)
                local completed_type
                completed_type=$(echo "$line" | jq -r '.item.type // empty' 2>/dev/null)

                case "$completed_type" in
                    agent_message)
                        local message_text
                        message_text=$(echo "$line" | jq -r '.item.text // empty' 2>/dev/null)
                        if [[ -n "$message_text" ]]; then
                            echo "$message_text"
                        fi
                        ;;
                    reasoning)
                        :
                        ;;
                    command_execution)
                        local completed_command completed_status completed_output completed_exit_code
                        completed_command=$(echo "$line" | jq -r '.item.command // empty' 2>/dev/null)
                        completed_status=$(echo "$line" | jq -r '.item.status // empty' 2>/dev/null)
                        completed_output=$(echo "$line" | jq -r '.item.aggregated_output // empty' 2>/dev/null)
                        completed_exit_code=$(echo "$line" | jq -r '.item.exit_code // empty' 2>/dev/null)

                        echo "<-- [exec] ${completed_status:-completed}"
                        if [[ -n "$completed_command" ]]; then
                            echo "    $(truncate_single_line "$completed_command" 200)"
                        fi
                        if [[ -n "$completed_exit_code" ]] && [[ "$completed_exit_code" != "null" ]]; then
                            echo "    Exit code: $completed_exit_code"
                        fi
                        if [[ -n "$completed_output" ]]; then
                            echo "    Output:"
                            print_preview_block "$completed_output" 8 1200
                        fi
                        ;;
                    file_change)
                        local patch_status
                        patch_status=$(echo "$line" | jq -r '.item.status // empty' 2>/dev/null)
                        echo "<-- [patch] ${patch_status:-completed}"
                        while IFS=$'\t' read -r kind path; do
                            local kind_label
                            if [[ -z "$path" ]]; then
                                continue
                            fi
                            case "$kind" in
                                add)
                                    kind_label="A"
                                    ;;
                                delete)
                                    kind_label="D"
                                    ;;
                                update)
                                    kind_label="M"
                                    ;;
                                *)
                                    kind_label="?"
                                    ;;
                            esac
                            echo "    $kind_label $path"
                        done < <(echo "$line" | jq -r '.item.changes[]? | "\(.kind)\t\(.path)"' 2>/dev/null)
                        ;;
                    mcp_tool_call)
                        local completed_server completed_tool completed_mcp_status completed_args completed_result completed_error
                        completed_server=$(echo "$line" | jq -r '.item.server // empty' 2>/dev/null)
                        completed_tool=$(echo "$line" | jq -r '.item.tool // empty' 2>/dev/null)
                        completed_mcp_status=$(echo "$line" | jq -r '.item.status // empty' 2>/dev/null)
                        completed_args=$(echo "$line" | jq -c '.item.arguments // {}' 2>/dev/null)
                        completed_result=$(echo "$line" | jq -c '.item.result.structured_content // .item.result.content // empty' 2>/dev/null)
                        completed_error=$(echo "$line" | jq -r '.item.error.message // empty' 2>/dev/null)

                        echo "<-- [mcp:$completed_server/$completed_tool] ${completed_mcp_status:-completed}"
                        if [[ "$completed_args" != "{}" ]] && [[ "$completed_args" != "null" ]] && [[ -n "$completed_args" ]]; then
                            echo "    Args: $(truncate_single_line "$completed_args" 200)"
                        fi
                        if [[ -n "$completed_result" ]] && [[ "$completed_result" != "null" ]] && [[ "$completed_result" != "[]" ]]; then
                            echo "    Result: $(truncate_single_line "$completed_result" 200)"
                        fi
                        if [[ -n "$completed_error" ]]; then
                            echo "    Error:"
                            print_preview_block "$completed_error" 8 1200
                        fi
                        ;;
                    collab_tool_call)
                        local completed_collab_tool completed_collab_status completed_receivers
                        completed_collab_tool=$(echo "$line" | jq -r '.item.tool // empty' 2>/dev/null)
                        completed_collab_status=$(echo "$line" | jq -r '.item.status // empty' 2>/dev/null)
                        completed_receivers=$(echo "$line" | jq -r '.item.receiver_thread_ids[]?' 2>/dev/null | paste -sd ',' -)

                        echo "<-- [collab:$completed_collab_tool] ${completed_collab_status:-completed}"
                        if [[ -n "$completed_receivers" ]]; then
                            echo "    Receivers: $completed_receivers"
                        fi
                        ;;
                    web_search)
                        local completed_query
                        completed_query=$(echo "$line" | jq -r '.item.query // empty' 2>/dev/null)
                        echo "<-- [web_search] $(truncate_single_line "$completed_query" 200)"
                        ;;
                    todo_list)
                        echo "==> Plan completed"
                        while IFS=$'\t' read -r completed text; do
                            if [[ -z "$text" ]]; then
                                continue
                            fi
                            if [[ "$completed" == "true" ]]; then
                                echo "    [x] $text"
                            else
                                echo "    [ ] $text"
                            fi
                        done < <(echo "$line" | jq -r '.item.items[]? | "\(.completed)\t\(.text)"' 2>/dev/null)
                        ;;
                    error)
                        local item_error
                        item_error=$(echo "$line" | jq -r '.item.message // empty' 2>/dev/null)
                        if [[ -n "$item_error" ]]; then
                            echo "ERROR: $item_error"
                        fi
                        ;;
                esac
                ;;
            turn.completed)
                local input_tokens cached_input_tokens output_tokens
                input_tokens=$(echo "$line" | jq -r '.usage.input_tokens // 0' 2>/dev/null)
                cached_input_tokens=$(echo "$line" | jq -r '.usage.cached_input_tokens // 0' 2>/dev/null)
                output_tokens=$(echo "$line" | jq -r '.usage.output_tokens // 0' 2>/dev/null)
                echo ""
                echo "==> Turn completed"
                echo "    Tokens: input=${input_tokens:-0}, cached_input=${cached_input_tokens:-0}, output=${output_tokens:-0}"
                ;;
            turn.failed)
                local failed_message
                failed_message=$(echo "$line" | jq -r '.error.message // empty' 2>/dev/null)
                echo ""
                echo "==> Turn failed"
                if [[ -n "$failed_message" ]]; then
                    echo "    $failed_message"
                fi
                ;;
            error)
                local error_message
                error_message=$(echo "$line" | jq -r '.message // empty' 2>/dev/null)
                if [[ -n "$error_message" ]]; then
                    echo "ERROR: $error_message"
                fi
                ;;
        esac
    done
}

run_claude_agent() {
    local worktree_path="$1"
    local dir="$2"
    local agent_prompt="$3"
    local log_file="$4"
    local notification_file="$5"

    (
        cd "$worktree_path" || exit 1
        claude --dangerously-skip-permissions --output-format "stream-json" --print --verbose --add-dir "$dir" -- "$agent_prompt"
    ) 2>&1 | \
        tee "$log_file" | \
        format_claude_json_stream | \
        tee "$notification_file"

    local pipeline_statuses=("${PIPESTATUS[@]}")
    return "${pipeline_statuses[0]:-0}"
}

run_codex_agent() {
    local worktree_path="$1"
    local dir="$2"
    local agent_prompt="$3"
    local log_file="$4"
    local notification_file="$5"
    local stderr_file last_message_file agent_exit_status

    stderr_file=$(mktemp)
    last_message_file=$(mktemp)

    if (
        cd "$worktree_path" || exit 1
        codex exec --json --color never --dangerously-bypass-approvals-and-sandbox --add-dir "$dir" -o "$last_message_file" -- "$agent_prompt" < /dev/null
    ) \
        > >(tee "$log_file" | format_codex_json_stream | tee "$notification_file") \
        2> >(tee "$stderr_file" >&2); then
        agent_exit_status=0
    else
        agent_exit_status=$?
    fi

    if [[ -s "$stderr_file" ]]; then
        {
            echo ""
            echo "==> STDERR"
            cat "$stderr_file"
        } >> "$notification_file"
    fi

    if [[ ! -s "$notification_file" ]] && [[ -s "$last_message_file" ]]; then
        cat "$last_message_file" >> "$notification_file"
    fi

    rm -f "$stderr_file" "$last_message_file"
    return "$agent_exit_status"
}

get_default_branch() {
    local repo_full_name="$1"
    gh repo view "$repo_full_name" --json defaultBranchRef --jq '.defaultBranchRef.name' 2>/dev/null
}

copy_env_files() {
    local source_dir="$1"
    local target_dir="$2"
    local env_file

    for env_file in "$source_dir"/.env "$source_dir"/.env.*; do
        if [[ -f "$env_file" ]]; then
            cp "$env_file" "$target_dir/" 2>/dev/null || true
        fi
    done
}

ensure_gh_agent_conflict_label() {
    local repo_full_name="$1"

    if ! gh label list --repo "$repo_full_name" --json name --jq '.[].name' 2>/dev/null | grep -qx "gh-agent-conflict"; then
        gh label create "gh-agent-conflict" \
            --repo "$repo_full_name" \
            --color "d93f0b" \
            --description "gh-agent: merge conflict requires resolution" \
            2>/dev/null || true
    fi
}

create_conflict_issue() {
    local repo_full_name="$1"
    local pr_number="$2"
    local branch_name="$3"
    local issue_number="$4"
    local issue_title="$5"

    ensure_gh_agent_conflict_label "$repo_full_name"

    local body
    body=$(cat <<EOF
Merge conflict detected between feature branch \`$branch_name\` and \`gh-agent\`.

**Pull Request:** #$pr_number
**Feature branch:** \`$branch_name\` (from issue #$issue_number: $issue_title)

To resolve:
1. Create a new branch from \`gh-agent\`
2. Merge \`$branch_name\` into it and resolve all conflicts
3. Push the resolution branch
4. Create a PR targeting \`gh-agent\` and merge it
5. Close this issue

Check issue #$issue_number to understand what changes \`$branch_name\` introduces when deciding how to resolve conflicts.
EOF
)

    gh issue create \
        --repo "$repo_full_name" \
        --title "gh-agent conflict: $branch_name into gh-agent (PR #$pr_number)" \
        --body "$body" \
        --label "gh-agent-conflict" \
        2>/dev/null || echo "Warning: could not create conflict issue for PR #$pr_number." >&2
}

get_next_issue() {
    local repo_full_name="$1"
    local issue_json

    issue_json=$(gh issue list \
        --repo "$repo_full_name" \
        --label "gh-agent-conflict" \
        --state open \
        --search "sort:created-asc" \
        --limit 1 \
        --json number,title,url 2>/dev/null) || issue_json='[]'

    if [[ "$(echo "$issue_json" | jq -r '.[0].number // empty' 2>/dev/null)" != "" ]]; then
        echo "$issue_json"
        return 0
    fi

    gh issue list \
        --repo "$repo_full_name" \
        --state open \
        --search "sort:created-asc" \
        --limit 1 \
        --json number,title,url 2>/dev/null
}

ensure_gh_agent_branch() {
    local repo_dir="$1"
    local repo_full_name="$2"
    local repo_owner="$3"
    local repo_name="$4"
    local default_branch="$5"
    local dry_run="${6:-false}"

    local gh_agent_worktree="$WORKTREE_DIR/$repo_owner/$repo_name/gh-agent"

    if [[ "$dry_run" == "true" ]]; then
        echo "Dry run: skipping gh-agent branch setup." >&2
        echo "$gh_agent_worktree"
        return 0
    fi

    # Fetch from origin; does not modify the base dir working tree
    git -C "$repo_dir" fetch origin >/dev/null 2>&1 || true
    git -C "$repo_dir" worktree prune >/dev/null 2>&1 || true

    mkdir -p "$(dirname "$gh_agent_worktree")"

    local existing_worktree
    existing_worktree=$(find_worktree_for_branch "$repo_dir" "gh-agent")

    if [[ -n "$existing_worktree" ]] && [[ "$existing_worktree" != "$gh_agent_worktree" ]]; then
        echo "gh-agent branch checked out at a different path: $existing_worktree" >&2
        gh_agent_worktree="$existing_worktree"
    elif [[ "$existing_worktree" == "$gh_agent_worktree" ]]; then
        echo "Reusing existing gh-agent worktree: $gh_agent_worktree" >&2
    elif git -C "$repo_dir" show-ref --verify --quiet "refs/heads/gh-agent"; then
        echo "Creating gh-agent worktree from existing local branch" >&2
        if ! git -C "$repo_dir" worktree add "$gh_agent_worktree" "gh-agent" 2>/dev/null; then
            echo "Failed to add gh-agent worktree from local branch" >&2
            return 1
        fi
        copy_env_files "$repo_dir" "$gh_agent_worktree"
    elif git -C "$repo_dir" ls-remote --exit-code --heads origin "gh-agent" >/dev/null 2>&1; then
        echo "Creating gh-agent worktree from remote branch" >&2
        if ! git -C "$repo_dir" worktree add --track -b "gh-agent" "$gh_agent_worktree" "origin/gh-agent" 2>/dev/null; then
            echo "Failed to add gh-agent worktree from remote branch" >&2
            return 1
        fi
        copy_env_files "$repo_dir" "$gh_agent_worktree"
    else
        echo "Creating gh-agent branch from origin/$default_branch" >&2
        if ! git -C "$repo_dir" worktree add -b "gh-agent" "$gh_agent_worktree" "origin/$default_branch" 2>/dev/null; then
            echo "Failed to create gh-agent branch and worktree" >&2
            return 1
        fi
        copy_env_files "$repo_dir" "$gh_agent_worktree"
    fi

    # Step 1: pull any remote gh-agent changes (another machine may have pushed to it)
    if git -C "$gh_agent_worktree" rev-parse --abbrev-ref --symbolic-full-name '@{upstream}' >/dev/null 2>&1; then
        echo "Pulling remote gh-agent changes..." >&2
        if ! git -C "$gh_agent_worktree" pull --ff-only >/dev/null 2>&1; then
            echo "Warning: could not fast-forward gh-agent from remote, remote may have diverged" >&2
        fi
    fi

    # Step 2: push local gh-agent state to remote (publishes branch on first run, syncs otherwise)
    echo "Pushing gh-agent to origin..." >&2
    if ! git -C "$gh_agent_worktree" push -u origin "gh-agent" >/dev/null 2>&1; then
        echo "Warning: failed to push gh-agent to origin" >&2
    fi

    # Step 3: merge default branch into gh-agent via PR
    echo "Checking for changes from $default_branch to sync into gh-agent..." >&2

    local existing_sync_pr_number
    existing_sync_pr_number=$(gh pr list \
        --repo "$repo_full_name" \
        --head "$default_branch" \
        --base "gh-agent" \
        --state open \
        --json number \
        --jq '.[0].number // empty' 2>/dev/null)

    local sync_pr_number
    if [[ -n "$existing_sync_pr_number" ]]; then
        sync_pr_number="$existing_sync_pr_number"
        echo "Found existing sync PR #$sync_pr_number, merging..." >&2
    else
        local sync_pr_url
        if sync_pr_url=$(gh pr create \
            --repo "$repo_full_name" \
            --head "$default_branch" \
            --base "gh-agent" \
            --title "Sync $default_branch into gh-agent" \
            --body "Automated sync of upstream $default_branch changes into gh-agent staging branch." \
            2>&1); then
            sync_pr_number=$(echo "$sync_pr_url" | grep -oE '[0-9]+$')
            echo "Created sync PR #$sync_pr_number" >&2
        else
            echo "No new changes to sync from $default_branch into gh-agent." >&2
        fi
    fi

    if [[ -n "$sync_pr_number" ]]; then
        echo "Merging sync PR #$sync_pr_number..." >&2
        if gh pr merge "$sync_pr_number" --repo "$repo_full_name" --merge 2>/dev/null; then
            echo "Synced $default_branch into gh-agent via PR #$sync_pr_number" >&2
        else
            echo "Warning: failed to merge sync PR #$sync_pr_number" >&2
        fi
    fi

    # Step 4: pull gh-agent after merge to bring local worktree up to date
    git -C "$gh_agent_worktree" pull --ff-only >/dev/null 2>&1 || true

    echo "$gh_agent_worktree"
}

sync_feature_to_gh_agent() {
    local gh_agent_worktree="$1"
    local repo_full_name="$2"
    local branch_name="$3"
    local issue_number="$4"
    local issue_title="$5"

    echo "Creating PR to merge $branch_name into gh-agent..."

    local pr_url pr_number
    if ! pr_url=$(gh pr create \
        --repo "$repo_full_name" \
        --head "$branch_name" \
        --base "gh-agent" \
        --title "merge $branch_name into gh-agent" \
        --body "Merging feature branch for issue #$issue_number: $issue_title into gh-agent staging branch." \
        2>/dev/null); then
        echo "Warning: could not create PR for $branch_name into gh-agent (may already exist or no changes)."
        return 0
    fi

    pr_number=$(echo "$pr_url" | grep -oE '[0-9]+$')
    echo "Created PR #$pr_number: $pr_url"

    echo "Merging PR #$pr_number into gh-agent..."
    if gh pr merge "$pr_number" --repo "$repo_full_name" --merge 2>/dev/null; then
        echo "Successfully merged $branch_name into gh-agent via PR #$pr_number."
        git -C "$gh_agent_worktree" pull --ff-only >/dev/null 2>&1 || true
    else
        echo "Merge conflict in PR #$pr_number. Creating conflict issue..."
        create_conflict_issue "$repo_full_name" "$pr_number" "$branch_name" "$issue_number" "$issue_title"
    fi
}

process_directory() {
    local dir="$1"
    local agent_provider="${2:-claude}"
    local dry_run="${3:-false}"

    echo ""
    echo "========================================"
    echo "Processing: $dir"
    echo "========================================"

    if ! is_git_repository "$dir"; then
        echo "Skipping (not a git repository): $dir"
        return 0
    fi

    # Determine repo identity (read-only, does not modify base dir working tree)
    local repo_namespace repo_owner repo_name repo_full_name
    if ! repo_namespace=$(get_repo_owner_and_name "$dir"); then
        echo "Skipping (could not determine owner/repo from remote.origin.url): $dir"
        return 0
    fi
    repo_owner=${repo_namespace%%/*}
    repo_name=${repo_namespace#*/}
    repo_full_name="$repo_owner/$repo_name"

    # Determine default branch via gh CLI
    local default_branch
    if ! default_branch=$(get_default_branch "$repo_full_name") || [[ -z "$default_branch" ]]; then
        echo "Skipping (could not determine default branch): $dir"
        return 0
    fi
    echo "Default branch: $default_branch"

    # Ensure gh-agent branch and worktree exist and are synced with the default branch.
    # This is the only place that touches git operations; the base dir working tree is never modified.
    local gh_agent_worktree
    if ! gh_agent_worktree=$(ensure_gh_agent_branch "$dir" "$repo_full_name" "$repo_owner" "$repo_name" "$default_branch" "$dry_run"); then
        echo "Skipping (could not ensure gh-agent branch): $dir"
        return 0
    fi
    echo "gh-agent worktree: $gh_agent_worktree"

    # Fetch next issue, prioritizing conflict resolution issues
    local issue_json
    if ! issue_json=$(get_next_issue "$repo_full_name"); then
        echo "Skipping (failed to fetch open issues): $dir"
        return 0
    fi

    local issue_number issue_title issue_url
    issue_number=$(echo "$issue_json" | jq -r '.[0].number // empty' 2>/dev/null)
    issue_title=$(echo "$issue_json" | jq -r '.[0].title // empty' 2>/dev/null)
    issue_url=$(echo "$issue_json" | jq -r '.[0].url // empty' 2>/dev/null)

    if [[ -z "$issue_number" ]] || [[ -z "$issue_title" ]]; then
        echo "No open issues found, skipping: $dir"
        return 0
    fi

    local branch_slug branch_name worktree_path
    branch_slug=$(slugify_branch_component "$issue_title")
    branch_name="${branch_slug}-issue-${issue_number}"
    worktree_path="$WORKTREE_DIR/$repo_owner/$repo_name/$branch_name"

    echo "Selected issue: #$issue_number - $issue_title"
    echo "Issue URL: $issue_url"
    echo "Repository: $repo_owner/$repo_name"
    echo "Branch name: $branch_name"
    echo "Worktree path: $worktree_path"

    local timestamp
    timestamp=$(date '+%Y%m%d_%H%M%S')
    local log_file="$LOG_DIR/${timestamp}_${repo_name}_issue_${issue_number}_${agent_provider}.json"
    local worktree_plan
    worktree_plan=$(determine_worktree_plan "$dir" "$branch_name" "$worktree_path")

    if [[ "$dry_run" == "true" ]]; then
        echo "Dry run: skipping worktree creation and worktree pull."
    else
        # Feature branch is created from gh-agent, not from the base dir HEAD
        if ! prepare_worktree "$dir" "$branch_name" "$worktree_path" "gh-agent"; then
            return 0
        fi

        if ! is_git_repository "$worktree_path"; then
            echo "Skipping (worktree was not created correctly): $worktree_path"
            return 0
        fi

        if is_working_tree_dirty "$worktree_path"; then
            echo "Skipping (dirty worktree): $worktree_path"
            return 0
        fi

        # Copy .env files from base dir so the agent has access to local config
        copy_env_files "$dir" "$worktree_path"

        if has_upstream_branch "$worktree_path"; then
            echo "Pulling latest changes in worktree..."
            if ! pull_fast_forward "$worktree_path" >/dev/null 2>&1; then
                echo "Skipping (failed to pull latest changes in worktree): $worktree_path"
                return 0
            fi

            if is_working_tree_dirty "$worktree_path"; then
                echo "Skipping (worktree became dirty after pull): $worktree_path"
                return 0
            fi
        fi
    fi

    echo "Starting to resolve issue #$issue_number..."

    local gh_login issue_snapshot_before issue_agent_comments_before pr_count_before
    local issue_thread_context agent_prompt

    if ! gh_login=$(get_current_gh_login); then
        echo "Skipping (failed to determine GitHub login for post-run validation): $dir"
        return 0
    fi

    if ! issue_snapshot_before=$(get_issue_runtime_snapshot "$repo_full_name" "$issue_number"); then
        echo "Skipping (failed to fetch initial issue state for validation): $dir"
        return 0
    fi

    issue_agent_comments_before=$(count_issue_comments_by_author_from_snapshot "$issue_snapshot_before" "$gh_login")
    if ! pr_count_before=$(get_pr_count_for_branch "$repo_full_name" "$branch_name"); then
        echo "Skipping (failed to fetch initial PR state for validation): $dir"
        return 0
    fi

    if ! issue_thread_context=$(build_issue_thread_context "$repo_full_name" "$issue_number"); then
        echo "Skipping (failed to fetch full issue conversation): $dir"
        return 0
    fi

    if [[ "$dry_run" == "true" ]]; then
        print_dry_run_summary \
            "$dir" \
            "$repo_full_name" \
            "$issue_number" \
            "$branch_name" \
            "$worktree_path" \
            "$worktree_plan" \
            "$log_file" \
            "$gh_login" \
            "$issue_snapshot_before" \
            "$issue_thread_context"
        return 0
    fi

    agent_prompt=$(cat <<EOF
Work only on GitHub issue #$issue_number: $issue_title
Issue URL: $issue_url
You are already inside the dedicated git worktree for this task on branch $branch_name at $worktree_path.
Do not choose another issue.
Do not create another branch.
Do not switch branches.
Before planning or coding, fetch and read the full current issue conversation with \`gh issue view $issue_number --repo $repo_full_name --comments\` so you have the latest issue body and all comments in context.
Here is the current issue conversation snapshot for convenience:

$issue_thread_context

Treat failing verification commands as part of the task. If analyze, test, typecheck, lint, or build commands fail, investigate and fix them when it is reasonably possible and necessary to complete the branch. Do not assume a failing command is an automatic blocker, and do not assume an existing repo error is out of scope if it blocks successful completion on this branch.
Normal completion flow: implement the solution, ensure all relevant tests pass and build/lint/typecheck succeeds when those commands exist, commit without co-author using conventional commit format if the repo uses it, push to $branch_name, and create a PR via gh cli targeting $default_branch that references issue #$issue_number. After the PR is created, close issue #$issue_number via gh cli.
Blocker flow: only if you cannot complete the task after reasonable investigation because you need external input, missing access, or an upstream problem you cannot safely fix, do not create a PR. Instead, if there are changes, commit and push the current branch state to $branch_name, add a comment to issue #$issue_number via gh cli describing the blocker and exactly what is needed to unblock it, and close issue #$issue_number via gh cli so it will not be retried until reopened.
If you hit a blocker, stop only after the blocker flow above is complete and explain the blocker clearly.
The wrapper will validate the final git and GitHub state after you finish, so do not claim completion unless the required side effects were actually performed.
Follow AGENTS.md and CLAUDE.md if present in the current directory or accessible added directories.
Never mention Claude, Claude Code, Codex, GPT, AI, or any LLM in commits, code comments, PR descriptions, or GitHub comments.
EOF
)

    echo "Agent provider: $agent_provider"
    echo "Logging to: $log_file"
    echo ""

    # Create temporary file for notification content
    local notification_file
    notification_file=$(mktemp)

    local agent_exit_status=0
    case "$agent_provider" in
        claude)
            run_claude_agent "$worktree_path" "$dir" "$agent_prompt" "$log_file" "$notification_file" || agent_exit_status=$?
            ;;
        codex)
            run_codex_agent "$worktree_path" "$dir" "$agent_prompt" "$log_file" "$notification_file" || agent_exit_status=$?
            ;;
        *)
            echo "Unsupported agent provider: $agent_provider"
            rm -f "$notification_file"
            return 0
            ;;
    esac

    local validation_status=0
    if validate_agent_outcome \
        "$worktree_path" \
        "$repo_full_name" \
        "$issue_number" \
        "$branch_name" \
        "$default_branch" \
        "$gh_login" \
        "$issue_agent_comments_before" \
        "$pr_count_before" \
        "$notification_file"; then
        validation_status=0
    else
        validation_status=$?
    fi

    # Send telegram notification silently
    if [[ -s "$notification_file" ]]; then
        tgn -t "gh-agent [$agent_provider]: $dir" < "$notification_file" 2>/dev/null >/dev/null || true
    fi
    rm -f "$notification_file"

    if [[ "$validation_status" -ne 0 ]]; then
        echo "Post-run validation failed"
        echo "Failed processing: $dir"
        return 0
    fi

    if [[ "$agent_exit_status" -ne 0 ]]; then
        echo "Agent exited with status: $agent_exit_status"
        echo "Post-run validation still passed"
    fi

    # Merge the completed feature branch into gh-agent via PR
    sync_feature_to_gh_agent \
        "$gh_agent_worktree" \
        "$repo_full_name" \
        "$branch_name" \
        "$issue_number" \
        "$issue_title"

    echo "Completed processing: $dir"
}

is_fifth_minute() {
    local current_minute
    current_minute=$(date +%M)
    # Remove leading zero for arithmetic
    current_minute=$((10#$current_minute))

    if (( current_minute % 5 == 0 )); then
        return 0
    else
        return 1
    fi
}

run_check_once() {
    local agent_provider="${1:-claude}"
    local dry_run="${2:-false}"
    local single_dir="$3"

    ensure_config

    local dirs
    if [[ -n "$single_dir" ]]; then
        dirs="$single_dir"
    else
        dirs=$(jq -r '.dirs[]' "$CONFIG_FILE" 2>/dev/null)
    fi

    if [[ -z "$dirs" ]]; then
        echo "No directories configured. Use '$(basename "$0") add [PATH]' to add directories."
        return 0
    fi

    echo "$dirs" | while read -r dir; do
        if [[ -d "$dir" ]]; then
            process_directory "$dir" "$agent_provider" "$dry_run"
        else
            echo "Skipping (directory not found): $dir"
        fi
    done
}

start_monitoring() {
    local agent_provider="${1:-claude}"
    local dry_run="${2:-false}"

    ensure_config

    if [[ "$dry_run" == "true" ]]; then
        echo "Running $(basename "$0") dry run (v$VERSION)"
        echo "Agent provider: $agent_provider"
        echo "Mode: dry run"
        echo ""
        run_check_once "$agent_provider" "true"
        return 0
    fi

    echo "Starting $(basename "$0") monitoring service (v$VERSION)"
    echo "Agent provider: $agent_provider"
    echo "Checking every 5 minutes (00, 05, 10, 15, 20, 25, 30, 35, 40, 45, 50, 55)"
    echo "Press Ctrl+C to stop"
    echo ""

    local last_run_minute=-1

    while true; do
        sleep 60

        local current_minute
        current_minute=$(date +%M)
        current_minute=$((10#$current_minute))

        # Skip if already ran this minute
        if [[ "$current_minute" == "$last_run_minute" ]]; then
            continue
        fi

        # Check if it's a 5th minute
        if is_fifth_minute; then
            last_run_minute=$current_minute

            echo ""
            echo "========================================"
            echo "Starting check at $(date '+%Y-%m-%d %H:%M:%S')"
            echo "========================================"

            run_check_once "$agent_provider" "$dry_run"

            echo ""
            echo "========================================"
            echo "Completed check at $(date '+%Y-%m-%d %H:%M:%S')"
            echo "Next check in ~5 minutes"
            echo "========================================"
        fi
    done
}

main() {
    if [[ $# -eq 0 ]]; then
        usage
        exit 0
    fi

    while [[ $# -gt 0 ]]; do
        case $1 in
            add)
                shift
                add_directory "$1"
                exit 0
                ;;
            remove)
                shift
                remove_directory "$1"
                exit 0
                ;;
            list)
                list_directories
                exit 0
                ;;
            logs)
                list_logs
                exit 0
                ;;
            dry-run)
                shift
                local dry_run_agent_provider="claude"
                local dry_run_path=""
                while [[ $# -gt 0 ]]; do
                    case $1 in
                        --claude)
                            dry_run_agent_provider="claude"
                            shift
                            ;;
                        --codex)
                            dry_run_agent_provider="codex"
                            shift
                            ;;
                        *)
                            if [[ -n "$dry_run_path" ]]; then
                                echo "Unknown option for dry-run: $1"
                                echo ""
                                usage
                                exit 1
                            fi
                            dry_run_path=$(get_absolute_path "$1")
                            shift
                            ;;
                    esac
                done
                if [[ -n "$dry_run_path" ]]; then
                    if [[ ! -d "$dry_run_path" ]]; then
                        echo "Error: Directory does not exist: $dry_run_path"
                        exit 1
                    fi
                    run_check_once "$dry_run_agent_provider" "true" "$dry_run_path"
                else
                    run_check_once "$dry_run_agent_provider" "true"
                fi
                exit 0
                ;;
            start)
                shift
                local agent_provider="claude"
                local dry_run="false"
                while [[ $# -gt 0 ]]; do
                    case $1 in
                        --claude)
                            agent_provider="claude"
                            shift
                            ;;
                        --codex)
                            agent_provider="codex"
                            shift
                            ;;
                        --dry-run)
                            dry_run="true"
                            shift
                            ;;
                        *)
                            echo "Unknown option for start: $1"
                            echo ""
                            usage
                            exit 1
                            ;;
                    esac
                done
                start_monitoring "$agent_provider" "$dry_run"
                exit 0
                ;;
            version)
                echo "$(basename "$0") version $VERSION"
                exit 0
                ;;
            -h|--help)
                usage
                exit 0
                ;;
            -v|--version)
                echo "$(basename "$0") version $VERSION"
                exit 0
                ;;
            *)
                echo "Unknown command: $1"
                echo ""
                usage
                exit 1
                ;;
        esac
    done
}

main "$@"
