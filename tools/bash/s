#!/usr/bin/env bash

set -euo pipefail

VERSION="1.0.0"
SCRIPT_NAME=$(basename "$0")

CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/s"
CONFIG_FILE="$CONFIG_DIR/config"
PORTS_DIR="$CONFIG_DIR/ports"

DEFAULT_SSH_USER="ash"
DEFAULT_DOMAIN="vimba-ph.ts.net"

usage() {
  cat <<EOF
Usage: ${SCRIPT_NAME} [ssh options] TARGET [remote command...]
       ${SCRIPT_NAME} port add PORTS TARGET
       ${SCRIPT_NAME} port remove PORTS TARGET
       ${SCRIPT_NAME} port list TARGET
       ${SCRIPT_NAME} config user USERNAME
       ${SCRIPT_NAME} config domain DOMAIN
       ${SCRIPT_NAME} config show

Commands:
  TARGET                     Connect to USER@TARGET.DOMAIN with saved forwards
  port add                   Add local forwards for TARGET
  port remove                Remove local forwards for TARGET
  port list                  Show saved forwarded ports for TARGET
  config user                Set the default SSH username
  config domain              Set the default SSH domain suffix
  config show                Show the active configuration

Shorthands:
  p                          Alias for port
  a                          Alias for add
  r                          Alias for remove
  l                          Alias for list

Examples:
  ${SCRIPT_NAME} dev
  ${SCRIPT_NAME} -J bastion dev
  ${SCRIPT_NAME} dev uptime
  ${SCRIPT_NAME} port add 3000 dev
  ${SCRIPT_NAME} p a 3000,3001-3003 dev
  ${SCRIPT_NAME} p r 3000-3002,4000 dev
  ${SCRIPT_NAME} port list dev
  ${SCRIPT_NAME} config user ash
  ${SCRIPT_NAME} config domain vimba-ph.ts.net
EOF
}

ensure_config() {
  mkdir -p "$CONFIG_DIR" "$PORTS_DIR"

  if [[ ! -f "$CONFIG_FILE" ]]; then
    cat > "$CONFIG_FILE" <<EOF
S_USER=${DEFAULT_SSH_USER}
S_DOMAIN=${DEFAULT_DOMAIN}
EOF
  fi
}

load_config() {
  ensure_config

  # shellcheck disable=SC1090
  source "$CONFIG_FILE"

  S_USER=${S_USER:-$DEFAULT_SSH_USER}
  S_DOMAIN=${S_DOMAIN:-$DEFAULT_DOMAIN}
}

save_config() {
  local user="$1"
  local domain="$2"

  ensure_config
  cat > "$CONFIG_FILE" <<EOF
S_USER=$(printf '%q' "$user")
S_DOMAIN=$(printf '%q' "$domain")
EOF
}

validate_target() {
  local target="$1"

  if [[ -z "$target" ]]; then
    echo "Error: target is required" >&2
    exit 1
  fi

  if [[ ! "$target" =~ ^[A-Za-z0-9._-]+$ ]]; then
    echo "Error: invalid target '$target'" >&2
    exit 1
  fi
}

validate_value() {
  local label="$1"
  local value="$2"

  if [[ -z "$value" ]]; then
    echo "Error: ${label} cannot be empty" >&2
    exit 1
  fi

  if [[ "$value" =~ [[:space:]] ]]; then
    echo "Error: ${label} cannot contain spaces" >&2
    exit 1
  fi
}

ports_file_for_target() {
  local target="$1"
  echo "$PORTS_DIR/${target}.ports"
}

expand_ports() {
  local spec="$1"
  local part start end port

  if [[ -z "$spec" ]]; then
    echo "Error: port specification is required" >&2
    exit 1
  fi

  IFS=',' read -ra parts <<< "$spec"

  for part in "${parts[@]}"; do
    part=${part//[[:space:]]/}

    if [[ -z "$part" ]]; then
      continue
    fi

    if [[ "$part" =~ ^([0-9]+)-([0-9]+)$ ]]; then
      start=${BASH_REMATCH[1]}
      end=${BASH_REMATCH[2]}

      if (( start > end )); then
        echo "Error: invalid port range '$part'" >&2
        exit 1
      fi

      for ((port = start; port <= end; port++)); do
        validate_port "$port"
        echo "$port"
      done
    elif [[ "$part" =~ ^[0-9]+$ ]]; then
      validate_port "$part"
      echo "$part"
    else
      echo "Error: invalid port entry '$part'" >&2
      exit 1
    fi
  done
}

validate_port() {
  local port="$1"

  if (( port < 1 || port > 65535 )); then
    echo "Error: invalid port '$port'" >&2
    exit 1
  fi
}

normalize_ports() {
  local spec="$1"

  expand_ports "$spec" | awk '!seen[$0]++' | sort -n
}

format_ports_inline() {
  if [[ $# -eq 0 ]]; then
    echo ""
    return
  fi

  printf '%s ' "$@" | sed 's/ $//'
}

get_saved_ports() {
  local target="$1"
  local file

  file=$(ports_file_for_target "$target")

  if [[ -f "$file" ]]; then
    sort -n "$file"
  fi
}

write_ports() {
  local target="$1"
  local file

  file=$(ports_file_for_target "$target")

  if [[ $# -eq 1 ]]; then
    rm -f "$file"
    return
  fi

  shift
  printf '%s\n' "$@" > "$file"
}

add_ports() {
  local spec="$1"
  local target="$2"
  local existing_file
  local port
  local -a existing=()
  local -a requested=()
  local -a merged=()

  validate_target "$target"
  existing_file=$(ports_file_for_target "$target")

  if [[ -f "$existing_file" ]]; then
    while IFS= read -r port; do
      [[ -n "$port" ]] && existing+=("$port")
    done < <(sort -n "$existing_file")
  fi

  while IFS= read -r port; do
    [[ -n "$port" ]] && requested+=("$port")
  done < <(normalize_ports "$spec")

  while IFS= read -r port; do
    [[ -n "$port" ]] && merged+=("$port")
  done < <(
    {
      if [[ ${#existing[@]} -gt 0 ]]; then
        printf '%s\n' "${existing[@]}"
      fi
      if [[ ${#requested[@]} -gt 0 ]]; then
        printf '%s\n' "${requested[@]}"
      fi
    } | awk 'NF && !seen[$0]++' | sort -n
  )

  if [[ ${#merged[@]} -eq 0 ]]; then
    echo "Error: no valid ports to save for ${target}" >&2
    exit 1
  fi

  write_ports "$target" "${merged[@]}"
  echo "Saved ports for ${target}: $(format_ports_inline "${merged[@]}")"
}

remove_ports() {
  local spec="$1"
  local target="$2"
  local file
  local port
  local -a existing=()
  local -a requested=()
  local -a remaining=()

  validate_target "$target"
  file=$(ports_file_for_target "$target")

  if [[ ! -f "$file" ]]; then
    echo "No saved ports for ${target}"
    return
  fi

  while IFS= read -r port; do
    [[ -n "$port" ]] && existing+=("$port")
  done < <(sort -n "$file")

  while IFS= read -r port; do
    [[ -n "$port" ]] && requested+=("$port")
  done < <(normalize_ports "$spec")

  if [[ ${#existing[@]} -eq 0 ]]; then
    echo "No saved ports for ${target}"
    return
  fi

  while IFS= read -r port; do
    [[ -n "$port" ]] && remaining+=("$port")
  done < <(
    printf '%s\n' "${existing[@]}" | awk '
      NR == FNR { remove[$0] = 1; next }
      !remove[$0]
    ' <(printf '%s\n' "${requested[@]}") -
  )

  if [[ ${#remaining[@]} -eq 0 ]]; then
    write_ports "$target"
    echo "Removed all saved ports for ${target}"
    return
  fi

  write_ports "$target" "${remaining[@]}"
  echo "Saved ports for ${target}: $(format_ports_inline "${remaining[@]}")"
}

list_ports() {
  local target="$1"
  local port
  local -a ports=()

  validate_target "$target"
  while IFS= read -r port; do
    [[ -n "$port" ]] && ports+=("$port")
  done < <(get_saved_ports "$target")

  if [[ ${#ports[@]} -eq 0 ]]; then
    echo "No saved ports for ${target}"
    return
  fi

  printf '%s\n' "${ports[@]}"
}

show_config() {
  load_config

  cat <<EOF
user: ${S_USER}
domain: ${S_DOMAIN}
config: ${CONFIG_FILE}
ports: ${PORTS_DIR}
EOF
}

connect_target() {
  load_config

  local -a cmd=()
  local -a ssh_options=()
  local -a remote_command=()
  local -a saved_ports=()
  local option=""
  local port
  local target="" destination=""

  while [[ $# -gt 0 ]]; do
    if [[ "$1" == "--" ]]; then
      shift

      while [[ $# -gt 0 ]]; do
        remote_command+=("$1")
        shift
      done
      break
    fi

    if [[ -z "$target" ]]; then
      if [[ "$1" == -* ]]; then
        option="$1"
        ssh_options+=("$option")
        shift

        if [[ $# -gt 0 ]] && [[ "$option" =~ ^-(b|c|D|E|e|F|I|i|J|L|l|m|O|o|p|Q|R|S|W|w)$ ]]; then
          ssh_options+=("$1")
          shift
        fi
        continue
      fi

      target="$1"
      shift
      continue
    fi

    remote_command+=("$1")
    shift
  done

  validate_target "$target"
  while IFS= read -r port; do
    [[ -n "$port" ]] && saved_ports+=("$port")
  done < <(get_saved_ports "$target")

  destination="${S_USER}@${target}.${S_DOMAIN}"

  if [[ ${#saved_ports[@]} -gt 0 ]]; then
    for port in "${saved_ports[@]}"; do
      ssh_options+=(-L "${port}:localhost:${port}")
    done
  fi

  cmd=(ssh)

  if [[ ${#ssh_options[@]} -gt 0 ]]; then
    cmd+=("${ssh_options[@]}")
  fi

  cmd+=("$destination")

  if [[ ${#remote_command[@]} -gt 0 ]]; then
    cmd+=("${remote_command[@]}")
  fi

  exec "${cmd[@]}"
}

handle_port_command() {
  local action="${1:-}"
  local spec="${2:-}"
  local target="${3:-}"

  case "$action" in
    add|a)
      if [[ -z "$spec" || -z "$target" ]]; then
        usage
        exit 1
      fi
      add_ports "$spec" "$target"
      ;;
    remove|r)
      if [[ -z "$spec" || -z "$target" ]]; then
        usage
        exit 1
      fi
      remove_ports "$spec" "$target"
      ;;
    list|l)
      if [[ -z "$spec" ]]; then
        usage
        exit 1
      fi
      list_ports "$spec"
      ;;
    *)
      usage
      exit 1
      ;;
  esac
}

handle_config_command() {
  local key="${1:-}"
  local value="${2:-}"

  load_config

  case "$key" in
    user)
      validate_value "user" "$value"
      save_config "$value" "$S_DOMAIN"
      echo "Saved default user: $value"
      ;;
    domain)
      validate_value "domain" "$value"
      save_config "$S_USER" "$value"
      echo "Saved default domain: $value"
      ;;
    show)
      show_config
      ;;
    *)
      usage
      exit 1
      ;;
  esac
}

main() {
  ensure_config

  case "${1:-}" in
    -h|--help|help)
      usage
      ;;
    -v|--version|version)
      echo "${SCRIPT_NAME} ${VERSION}"
      ;;
    port|p)
      shift
      handle_port_command "${1:-}" "${2:-}" "${3:-}"
      ;;
    config)
      shift
      handle_config_command "${1:-}" "${2:-}"
      ;;
    *)
      connect_target "$@"
      ;;
  esac
}

main "$@"
