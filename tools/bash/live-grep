#!/usr/bin/env bash
set -euo pipefail

xdg_config_home="${XDG_CONFIG_HOME:-$HOME/.config}"
exclude_cfg="$xdg_config_home/live-grep/exclude-globs"
include_cfg="$xdg_config_home/live-grep/include-globs"
exclude_args=()
include_args=()

if [ -f "$exclude_cfg" ]; then
  while IFS= read -r pat || [ -n "$pat" ]; do
    [ -z "$pat" ] && continue
    case "$pat" in
      \#*) continue ;;
    esac
    exclude_args+=(--glob "!$pat")
    exclude_args+=(--glob "!**/$pat")
  done < "$exclude_cfg"
fi

if [ -f "$include_cfg" ]; then
  while IFS= read -r pat || [ -n "$pat" ]; do
    [ -z "$pat" ] && continue
    case "$pat" in
      \#*) continue ;;
    esac
    include_args+=(--glob "$pat")
    include_args+=(--glob "**/$pat")
  done < "$include_cfg"
fi

base_args=(
  --color=never
  --no-heading
  --with-filename
  --line-number
  --column
  --smart-case
  --hidden
)

{
  rg "${base_args[@]}" "${exclude_args[@]}" "$@" 2>/dev/null || true
  if [ "${#include_args[@]}" -gt 0 ]; then
    rg "${base_args[@]}" --no-ignore "${include_args[@]}" "${exclude_args[@]}" "$@" 2>/dev/null || true
  fi
} | awk '!seen[$0]++'
